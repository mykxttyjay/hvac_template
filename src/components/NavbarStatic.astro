---
import { siteConfig } from "@/config/site"
import { utilityNavItems, mainNavItems, quickActions } from "@/config/navigation"
---

<!-- Hidden checkbox — CSS-only mobile drawer toggle, zero JS -->
<input type="checkbox" id="nb-mobile-toggle" class="nb-mobile-toggle-input" aria-hidden="true" />

<header class="nb-header">
  <!-- ── Row 0: Black info bar (address & email on left, navigation on right) ── -->
  <div class="nb-info-bar">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="nb-info-inner">
        <!-- Left: Address & Email -->
        <div class="nb-info-left">
          <a href="#" class="nb-info-link">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {siteConfig.location.fullAddress}
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} class="nb-info-link">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {siteConfig.contact.email}
          </a>
        </div>
        
        <!-- Right: Main Navigation (HOME - SERVICE AREAS) -->
        <nav class="nb-info-nav" aria-label="Main navigation">
          {utilityNavItems.map((item) => (
            item.children ? (
              <div class="nb-info-dropdown">
                <a href={item.href} class="nb-info-nav-link">
                  {item.title}
                  <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                </a>
                <div class="nb-info-panel">
                  <div class="nb-info-panel-bar"></div>
                  {item.children.map((child) => (
                    <a href={child.href} class="nb-info-child">{child.title}</a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={item.href} class="nb-info-nav-link">{item.title}</a>
            )
          ))}
        </nav>
      </div>
    </div>
  </div>

  <!-- ── Row 1: Logo + Maintenance/Financing + Call Button ── -->
  <div class="nb-top">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="nb-top-inner">
        <a href="/" class="nb-logo" aria-label={`${siteConfig.business.name} - Home`}>
          <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="nb-logo-img" width="44" height="44" decoding="async" loading="eager" />
          <span class="nb-logo-name">{siteConfig.business.name}</span>
        </a>
        
        <!-- Center: Maintenance Plan & Financing buttons -->
        <div class="nb-top-actions">
          {quickActions.map((action) => (
            <a href={action.href} class="nb-top-action-btn">
              {action.icon === "settings" ? (
                <svg class="nb-action-icon" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97 0-.33-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.31-.61-.22l-2.49 1c-.52-.39-1.06-.73-1.69-.98l-.37-2.65A.506.506 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.63.25-1.17.59-1.69.98l-2.49-1c-.22-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1 0 .33.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.06.74 1.69.99l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.63-.26 1.17-.59 1.69-.99l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.66z"/>
                </svg>
              ) : (
                <svg class="nb-action-icon" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"/>
                </svg>
              )}
              <span class="nb-action-text">{action.title}</span>
            </a>
          ))}
        </div>
        
        <!-- Phone button -->
        <a href={`tel:${siteConfig.contact.phone}`} class="nb-top-phone-btn">
          <svg class="nb-phone-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          <div class="nb-phone-text">
            <span class="nb-phone-label">CALL OR TEXT</span>
            <span class="nb-phone-number">{siteConfig.contact.phoneFormatted}</span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- ── Row 2: Service bar ── -->
  <div class="nb-bar">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="nb-bar-inner">

        <!-- Desktop service nav with CSS mega menus -->
        <nav class="nb-service-nav" aria-label="Service navigation">
          {mainNavItems.map((item) => (
            <div class="nb-nav-item">
              <a href={item.href} class="nb-nav-link">
                {item.title}
                <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </a>
              <span class="nb-nav-underline" aria-hidden="true"></span>
              <div class="nb-mega" role="region" aria-label={`${item.title} submenu`}>
                <div class="nb-mega-bar"></div>
                <div class="nb-mega-inner">
                  <div class="nb-mega-links">
                    {item.categories.flatMap((cat) => cat.items).map((service) => (
                      <a href={service.href} class="nb-mega-link">
                        <span class="nb-mega-dot" aria-hidden="true"></span>
                        {service.title}
                      </a>
                    ))}
                  </div>
                  <div class="nb-mega-footer">
                    <a href={item.href} class="nb-mega-view-all">
                      View all {item.title.toLowerCase()}
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </nav>

        <!-- Mobile: logo + hamburger label (CSS toggle, no JS) -->
        <a href="/" class="nb-mobile-logo" aria-label={`${siteConfig.business.name} - Home`}>
          <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="h-9 w-9 object-contain" width="36" height="36" decoding="async" loading="eager" />
          <span class="nb-mobile-name">{siteConfig.business.name}</span>
        </a>
        <label for="nb-mobile-toggle" class="nb-hamburger" aria-label="Open menu" role="button" tabindex="0">
          <svg class="nb-ham-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="nb-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </label>
      </div>
    </div>
  </div>
</header>

<!-- Mobile drawer — pure CSS, no JS, no React -->
<div class="nb-mobile-drawer" id="mobile-nav" role="dialog" aria-label="Mobile navigation">
  <!-- Backdrop -->
  <label for="nb-mobile-toggle" class="nb-backdrop" aria-hidden="true"></label>

  <!-- Drawer panel -->
  <div class="nb-drawer-panel">
    <!-- Phone CTA -->
    <a href={`tel:${siteConfig.contact.phone}`} class="nb-drawer-phone">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {siteConfig.contact.phoneFormatted}
    </a>

    <!-- Utility links -->
    <div class="nb-drawer-section nb-drawer-section--muted">
      {utilityNavItems.map((item) => (
        item.children ? (
          <details class="nb-drawer-details">
            <summary class="nb-drawer-summary">
              {item.title}
              <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="nb-drawer-children">
              {item.children.map((child) => (
                <a href={child.href} class="nb-drawer-child">{child.title}</a>
              ))}
            </div>
          </details>
        ) : (
          <a href={item.href} class="nb-drawer-link">{item.title}</a>
        )
      ))}
    </div>

    <!-- Services -->
    <div class="nb-drawer-section nb-drawer-section--white">
      <p class="nb-drawer-section-label">Services</p>
      {mainNavItems.map((service) => (
        <details class="nb-drawer-details">
          <summary class="nb-drawer-summary">
            {service.title}
            <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="nb-drawer-children">
            {service.categories.flatMap((cat) => cat.items).map((link) => (
              <a href={link.href} class="nb-drawer-child">{link.title}</a>
            ))}
          </div>
        </details>
      ))}
    </div>

    <!-- Quick actions -->
    <div class="nb-drawer-actions">
      {quickActions.map((action, i) => (
        <a href={action.href} class={`nb-drawer-action ${i > 0 ? "nb-drawer-action--border" : ""}`}>
          {action.icon === "settings" ? (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          ) : (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          )}
          {action.title}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  /* ── Toggle input (hidden, drives CSS state) ── */
  .nb-mobile-toggle-input {
    position: fixed;
    opacity: 0;
    pointer-events: none;
    width: 0; height: 0;
  }

  /* ── Header ── */
  .nb-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  /* ── Row 0: Black info bar (address & email on left, navigation on right) ── */
  .nb-info-bar {
    display: none;
    background: #000000;
  }
  @media (min-width: 1024px) { .nb-info-bar { display: block; } }

  .nb-info-inner {
    display: flex;
    height: 40px;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  
  .nb-info-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .nb-info-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nb-info-link:hover { color: var(--brand-highlight); }
  .nb-info-link svg { color: var(--brand-highlight); flex-shrink: 0; }
  
  /* Navigation on right side of black bar */
  .nb-info-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    height: 100%;
  }
  
  .nb-info-nav-link {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.2s;
    height: 100%;
  }
  .nb-info-nav-link:hover { color: var(--brand-highlight); }
  
  .nb-info-dropdown { 
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }
  .nb-info-panel {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    padding: 0.5rem 0;
    width: max-content;
    z-index: 95;
    border-radius: 4px;
    margin-top: 0.5rem;
  }
  .nb-info-panel::before {
    content: '';
    position: absolute;
    top: -0.5rem;
    left: 0;
    right: 0;
    height: 0.5rem;
    background: transparent;
  }
  .nb-info-panel-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--brand-highlight);
    border-radius: 4px 4px 0 0;
  }
  .nb-info-dropdown:hover .nb-info-panel { display: block; }
  .nb-info-child {
    display: block;
    padding: 0.75rem 1.25rem;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .nb-info-child:hover { 
    color: var(--brand-highlight); 
    background: color-mix(in srgb, var(--brand-highlight) 10%, transparent);
  }
  .nb-chevron { width: 0.625rem; height: 0.625rem; flex-shrink: 0; }

  /* ── Top bar (desktop only) ── */
  .nb-top {
    display: none;
    background: var(--brand-primary);
  }
  @media (min-width: 1024px) { .nb-top { display: block; } }

  .nb-top-inner {
    display: flex;
    height: 68px;
    align-items: center;
    gap: 2rem;
    justify-content: space-between;
  }
  .nb-logo {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-shrink: 0;
    text-decoration: none;
  }
  .nb-logo-img {
    height: 44px; width: 44px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .nb-logo-name {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }
  
  /* Center action buttons in Row 1 */
  .nb-top-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }
  
  .nb-top-action-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: transparent;
    border: none;
    color: #ffffff;
    padding: 0.5rem 1rem;
    font-size: 18px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
    position: relative;
  }
  
  .nb-action-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--brand-highlight);
    transition: all 0.3s ease;
  }
  
  .nb-action-text {
    font-size: 18px;
    font-weight: 600;
  }
  
  .nb-top-action-btn:hover {
    color: var(--brand-highlight);
  }
  
  .nb-top-action-btn:hover .nb-action-icon {
    color: #ff9d2e;
    transform: scale(1.15);
  }

  /* Top phone button - enhanced design */
  .nb-top-phone-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: transparent;
    color: #ffffff;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
    position: relative;
    flex-shrink: 0;
    margin-left: auto;
  }
  
  .nb-phone-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: var(--brand-highlight);
    animation: phoneRing 2.5s ease-in-out infinite;
    transition: all 0.3s ease;
  }
  
  .nb-phone-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.125rem;
  }
  
  .nb-phone-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.85);
  }
  
  .nb-phone-number {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--brand-highlight);
  }
  
  .nb-top-phone-btn:hover { 
    transform: translateY(-2px);
  }
  
  .nb-top-phone-btn:hover .nb-phone-icon {
    transform: scale(1.1);
    color: #ff9d2e;
  }
  
  .nb-top-phone-btn:hover .nb-phone-number {
    color: #ff9d2e;
  }
  
  @keyframes phoneRing {
    0%, 100% { transform: rotate(0deg); }
    5%, 15% { transform: rotate(-15deg); }
    10%, 20% { transform: rotate(15deg); }
    25% { transform: rotate(0deg); }
  }

  /* ── Service bar ── */
  .nb-bar {
    background: #fef9f3;
    border-bottom: 1px solid color-mix(in srgb, var(--brand-highlight) 20%, transparent);
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .nb-bar-inner {
    display: flex;
    height: 64px;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  /* Desktop service nav — hidden on mobile, centered */
  .nb-service-nav {
    display: none;
    height: 64px;
  }
  @media (min-width: 1024px) { .nb-service-nav { display: flex; } }

  .nb-nav-item {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .nb-nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0 0.75rem;
    height: 100%;
    font-size: 15px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--brand-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .nb-nav-link:hover, .nb-nav-item:hover .nb-nav-link { color: var(--brand-highlight); }
  .nb-nav-underline {
    position: absolute;
    bottom: 0; left: 0.75rem; right: 0.75rem;
    height: 3px;
    background: var(--brand-highlight);
    transform: scaleX(0);
    transition: transform 0.2s;
  }
  .nb-nav-item:hover .nb-nav-underline { transform: scaleX(1); }

  /* Mega menu — CSS hover, no JS */
  .nb-mega {
    display: none;
    position: absolute;
    left: 0;
    top: 100%;
    z-index: 90;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    min-width: 280px;
    max-width: 320px;
  }
  .nb-nav-item:hover .nb-mega { display: block; }
  .nb-mega-inner { background: #fff; padding: 1.25rem 1.5rem; }
  .nb-mega-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }
  .nb-mega-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    color: var(--brand-secondary);
    text-decoration: none;
    transition: all 0.2s;
    border-radius: 4px;
  }
  .nb-mega-link:hover { 
    color: var(--brand-primary);
    background: color-mix(in srgb, var(--brand-highlight) 8%, transparent);
  }
  .nb-mega-dot {
    display: none;
  }
  .nb-mega-footer {
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in srgb, var(--brand-highlight) 15%, transparent);
  }
  .nb-mega-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--brand-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
