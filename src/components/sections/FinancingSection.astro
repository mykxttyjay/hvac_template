---
interface Step {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  paymentPlans: string[];
  financingOptions: string[];
  steps: Step[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  badge,
  title,
  description,
  paymentPlans,
  financingOptions,
  steps,
  buttonText = "Apply Now",
  buttonHref = "/financing",
} = Astro.props;
---

<section class="fin-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Header -->
    <div class="fin-header" data-animate="fade-scale">
      <div class="fin-eyebrow">
        <span class="fin-eyebrow-text">Financing</span>
      </div>
      <h2 class="fin-title">{title}</h2>
      <div class="fin-divider"></div>
      <p class="fin-desc" set:html={description} />
    </div>

    <!-- Two-column lists -->
    <div class="fin-lists">
      <div class="fin-list-card" data-animate="fade-right">
        <div class="fin-list-header">
          <span class="fin-list-accent"></span>
          <h3 class="fin-list-heading">Why Choose Our Financing?</h3>
        </div>
        <ul class="fin-list">
          {paymentPlans.map((plan) => (
            <li class="fin-list-item">
              <span class="fin-check-dot"></span>
              <span>{plan}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="fin-list-card" data-animate="fade-left" data-animate-delay="200">
        <div class="fin-list-header">
          <span class="fin-list-accent"></span>
          <h3 class="fin-list-heading">What Can You Finance?</h3>
        </div>
        <ul class="fin-list">
          {financingOptions.map((option) => (
            <li class="fin-list-item">
              <span class="fin-check-dot"></span>
              <span>{option}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Steps -->
    <div class="fin-steps" data-animate-stagger>
      {steps.map((step, i) => (
        <div class="fin-step">
          <div class="fin-step-top">
            <div class="fin-step-num">{String(i + 1).padStart(2, '0')}</div>
            {i < steps.length - 1 && <div class="fin-step-line" aria-hidden="true"></div>}
          </div>
          <h4 class="fin-step-title">{step.title}</h4>
          <p class="fin-step-text" set:html={step.description} />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="fin-cta" data-animate="fade-up">
      <a href={buttonHref} class="fin-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fin-section {
    background: var(--brand-tertiary);
    position: relative;
  }

  /* ─── Header ─── */
  .fin-header {
    text-align: center;
    margin-bottom: 3.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .fin-eyebrow {
    margin-bottom: 1.25rem;
  }
  .fin-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  .fin-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .fin-title { font-size: 2.25rem; }
  }

  .fin-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }

  .fin-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── List cards ─── */
  .fin-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 64rem;
    margin: 0 auto 3.5rem;
  }

  .fin-list-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 2rem;
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
    position: relative;
    overflow: hidden;
  }
  .fin-list-card:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }

  .fin-list-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .fin-list-accent {
    width: 3px;
    height: 24px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }

  .fin-list-heading {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
  }

  .fin-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fin-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--brand-secondary);
    font-weight: 500;
  }

  .fin-check-dot {
    width: 8px;
    height: 8px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }

  /* ─── Steps ─── */
  .fin-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 56rem;
    margin: 0 auto 3rem;
  }

  .fin-step {
    text-align: center;
    position: relative;
  }

  .fin-step-top {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    position: relative;
  }

  .fin-step-num {
    width: 3.25rem;
    height: 3.25rem;
    background: var(--brand-primary);
    color: var(--brand-highlight);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    border: 2px solid var(--brand-highlight);
  }

  .fin-step-line {
    position: absolute;
    top: 50%;
    left: calc(50% + 2rem);
    width: calc(100% - 2rem);
    height: 2px;
    background: var(--brand-highlight);
    opacity: 0.25;
    z-index: 1;
  }

  .fin-step-title {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
    margin-bottom: 0.35rem;
  }

  .fin-step-text {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--brand-secondary);
  }

  /* ─── CTA ─── */
  .fin-cta {
    text-align: center;
  }

  .fin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.8rem 2rem;
    background: var(--brand-primary);
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .fin-btn:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: translateX(4px);
  }
  .fin-btn svg {
    transition: transform 0.3s ease;
  }
  .fin-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .fin-lists {
      grid-template-columns: 1fr;
    }
    .fin-steps {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
    .fin-step-line {
      display: none;
    }
  }
</style>
