---
interface Step {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  paymentPlans: string[];
  financingOptions: string[];
  steps: Step[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  badge,
  title,
  description,
  paymentPlans,
  financingOptions,
  steps,
  buttonText = "Apply Now",
  buttonHref = "/financing",
} = Astro.props;
---

<section class="fin-section" style="background-image: url('https://images.unsplash.com/photo-1615799998603-7c6270a45196?q=80&w=704&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'); background-size: cover; background-position: center; background-attachment: fixed;">
  <div class="absolute inset-0 bg-white/75"></div>
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-16 relative z-10">

    <!-- Header -->
    <div class="fin-header" data-animate="fade-scale">
      <div class="fin-eyebrow">
        <svg class="fin-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        <span class="fin-eyebrow-text">Financing</span>
      </div>
      <h2 class="fin-title">{title}</h2>
      <p class="fin-desc" set:html={description} />
    </div>

    <!-- Two-column lists -->
    <div class="fin-lists">
      <div class="fin-list-card" data-animate="fade-right">
        <div class="fin-list-header">
          <span class="fin-list-accent"></span>
          <h3 class="fin-list-heading">Why Choose Our Financing?</h3>
        </div>
        <ul class="fin-list">
          {paymentPlans.map((plan) => (
            <li class="fin-list-item">
              <span class="fin-check-dot"></span>
              <span>{plan}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="fin-list-card" data-animate="fade-left" data-animate-delay="200">
        <div class="fin-list-header">
          <span class="fin-list-accent"></span>
          <h3 class="fin-list-heading">What Can You Finance?</h3>
        </div>
        <ul class="fin-list">
          {financingOptions.map((option) => (
            <li class="fin-list-item">
              <span class="fin-check-dot"></span>
              <span>{option}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Steps -->
    <div class="fin-steps" data-animate-stagger>
      {steps.map((step, i) => (
        <div class="fin-step">
          <div class="fin-step-top">
            <div class="fin-step-num">{String(i + 1).padStart(2, '0')}</div>
            {i < steps.length - 1 && <div class="fin-step-line" aria-hidden="true"></div>}
          </div>
          <h4 class="fin-step-title">{step.title}</h4>
          <p class="fin-step-text" set:html={step.description} />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="fin-cta" data-animate="fade-up">
      <a href={buttonHref} class="fin-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fin-section {
    background: var(--brand-tertiary);
    position: relative;
    overflow: hidden;
  }

  /* ─── Header ─── */
  .fin-header {
    text-align: center;
    margin-bottom: 3.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .fin-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .fin-fan-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .fin-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    background: none;
    border: none;
    margin: 0;
  }

  .fin-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .fin-title { font-size: 45px; }
  }

  .fin-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }

  .fin-desc {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--brand-primary);
    margin-top: 1rem;
  }

  /* ─── List cards ─── */
  .fin-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 64rem;
    margin: 0 auto 3.5rem;
  }

  .fin-list-card {
    background: white;
    border: 2px solid var(--brand-highlight);
    padding: 2rem;
    transition: box-shadow 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(244, 145, 29, 0.1);
  }
  .fin-list-card:hover {
    border-color: var(--brand-primary);
    box-shadow: 0 12px 32px rgba(244, 145, 29, 0.2);
    transform: translateY(-4px);
  }

  .fin-list-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .fin-list-accent {
    width: 3px;
    height: 24px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }

  .fin-list-heading {
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
  }

  .fin-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fin-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--brand-primary);
    font-weight: 500;
  }

  .fin-check-dot {
    width: 8px;
    height: 8px;
    background: var(--brand-highlight);
    flex-shrink: 0;
    border-radius: 50%;
  }

  /* ─── Steps ─── */
  .fin-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    max-width: 100%;
    margin: 0 auto 3rem;
    position: relative;
    flex-wrap: wrap;
    width: 100%;
  }

  .fin-step {
    text-align: center;
    position: relative;
    flex: 1;
    min-width: 200px;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0 3.5rem;
  }
  
  .fin-step:first-child {
    max-width: 240px;
  }

  .fin-step-top {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    position: relative;
    width: 100%;
  }

  .fin-step-num {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--brand-highlight) 0%, #ff9d2e 100%);
    color: white;
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    border: none;
    border-radius: 50%;
    box-shadow: 0 4px 15px rgba(244, 145, 29, 0.3);
  }

  .fin-step-line {
    position: absolute;
    top: 40px;
    left: calc(50% + 45px);
    width: calc(100% + 7rem - 45px);
    height: 2px;
    background: var(--brand-highlight);
    opacity: 0.4;
    z-index: 1;
  }
  
  .fin-step-line::after {
    content: '→';
    position: absolute;
    right: -8px;
    top: -8px;
    font-size: 1.5rem;
    color: var(--brand-highlight);
    font-weight: bold;
  }
  
  .fin-step:last-child .fin-step-line {
    display: none;
  }

  .fin-step-title {
    font-size: 1.125rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-primary);
    margin-bottom: 0.75rem;
  }

  .fin-step-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--brand-secondary);
  }

  /* ─── CTA ─── */
  .fin-cta {
    text-align: center;
  }

  .fin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.8rem 2rem;
    background: var(--brand-primary);
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .fin-btn:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: translateX(4px);
  }
  .fin-btn svg {
    transition: transform 0.3s ease;
  }
  .fin-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .fin-lists {
      grid-template-columns: 1fr;
    }
    .fin-steps {
      flex-direction: column;
      gap: 2rem;
    }
    .fin-step {
      max-width: 100%;
    }
    .fin-step-line {
      display: none;
    }
    .fin-step-num {
      width: 70px;
      height: 70px;
      font-size: 1.25rem;
    }
  }
</style>
