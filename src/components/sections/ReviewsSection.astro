---
import { getLocationText } from "@/config/site"

interface Review {
  name: string;
  time: string;
  content: string;
  readMoreHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  reviews: Review[];
}

const { badge = "GOOGLE REVIEW", title: rawTitle, description: rawDescription, reviews: rawReviews } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const reviews = rawReviews.map(r => ({ ...r, content: getLocationText(r.content) }));
---

<section class="rv-section">
  <div class="rv-body">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">

      <!-- Header -->
      <div class="rv-header" data-animate="fade-up">
        <div class="rv-eyebrow">
          <span class="rv-eyebrow-text">{badge}</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
          <h2 class="rv-title">{title}</h2>
          {description && <p class="rv-desc" set:html={description} />}
        </div>
      </div>

      <!-- Carousel -->
      <div class="rv-carousel" data-animate="fade-up" data-animate-delay="100">
        <div class="rv-viewport">
          <div class="rv-track">
            {reviews.map((review) => (
              <div class="rv-slide">
                <div class="rv-card group">
                  <span class="rv-card-strip"></span>

                  <div class="rv-card-inner">
                    <!-- Top: quote + stars -->
                    <div class="rv-card-top">
                      <div class="rv-quote" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                      </div>
                      <div class="rv-stars" role="img" aria-label="5 out of 5 stars">
                        {Array.from({ length: 5 }).map(() => (
                          <svg xmlns="http://www.w3.org/2000/svg" class="rv-star" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        ))}
                      </div>
                    </div>

                    <!-- Content -->
                    <p class="rv-content" set:html={review.content} />

                    <!-- Author -->
                    <div class="rv-author">
                      <div class="rv-avatar">
                        <span>{review.name.split(' ').map(n => n[0]).join('')}</span>
                      </div>
                      <div class="rv-author-info">
                        <span class="rv-name">{review.name}</span>
                        <span class="rv-date">{review.time}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Controls -->
        <div class="rv-controls">
          <button class="rv-arrow rv-arrow--prev" aria-label="Previous reviews">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <div class="rv-dots"></div>
          <button class="rv-arrow rv-arrow--next" aria-label="Next reviews">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rv-section {
    position: relative;
    background: var(--background);
  }

  .rv-body {
    background: #fff;
    padding: 4rem 0 5rem;
  }

  /* ─── Header ─── */
  .rv-header {
    margin-bottom: 2.5rem;
  }

  .rv-eyebrow {
    margin-bottom: 1.5rem;
  }
  .rv-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  .rv-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) {
    .rv-title { font-size: 2.5rem; }
  }

  .rv-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Carousel ─── */
  .rv-carousel {
    position: relative;
  }

  .rv-viewport {
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }
  .rv-viewport:active {
    cursor: grabbing;
  }

  .rv-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }
  .rv-track.is-dragging {
    transition: none;
  }

  .rv-slide {
    flex-shrink: 0;
    width: calc(100% / 3);
    padding: 0 0.625rem;
    box-sizing: border-box;
  }

  /* ─── Card ─── */
  .rv-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.18);
    overflow: hidden;
    transition: all 0.35s ease;
    height: 100%;
  }
  .rv-card:hover {
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  .rv-card-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
    z-index: 1;
  }
  .rv-card:hover .rv-card-strip {
    height: 100%;
  }

  .rv-card-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 320px;
  }

  .rv-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .rv-quote {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-tertiary);
    border: 1px solid rgba(0,0,0,0.06);
    color: var(--brand-primary);
    transition: all 0.3s ease;
  }
  .rv-card:hover .rv-quote {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    color: var(--brand-primary);
  }

  .rv-stars {
    display: flex;
    gap: 2px;
  }
  .rv-star {
    color: var(--brand-highlight);
  }

  .rv-content {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--brand-secondary);
    flex: 1;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rv-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .rv-avatar {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--brand-primary);
    color: var(--brand-highlight);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }
  .rv-card:hover .rv-avatar {
    background: var(--brand-highlight);
    color: var(--brand-primary);
  }
  .rv-author-info { display: flex; flex-direction: column; }
  .rv-name {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
  }
  .rv-date {
    font-size: 0.7rem;
    color: var(--brand-secondary);
    letter-spacing: 0.05em;
  }

  /* ─── Controls ─── */
  .rv-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .rv-arrow {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .rv-arrow:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    border-color: var(--brand-highlight);
  }

  .rv-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .rv-dots :global(button) {
    width: 24px;
    height: 3px;
    border: none;
    background: rgba(0,0,0,0.15);
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }
  .rv-dots :global(button.is-active) {
    background: var(--brand-highlight);
    width: 40px;
  }

  /* ─── Responsive ─── */
  @media (max-width: 1280px) {
    .rv-slide { width: calc(100% / 3); }
  }
  @media (max-width: 1024px) {
    .rv-slide { width: 50%; }
  }
  @media (max-width: 640px) {
    .rv-slide {
      width: 100%;
      padding: 0 0.375rem;
    }
  }
</style>

<script>
  function initReviewsCarousel() {
    document.querySelectorAll<HTMLElement>('.rv-carousel').forEach((carousel) => {
      const viewport = carousel.querySelector<HTMLElement>('.rv-viewport');
      const track = carousel.querySelector<HTMLElement>('.rv-track');
      const prevBtn = carousel.querySelector<HTMLElement>('.rv-arrow--prev');
      const nextBtn = carousel.querySelector<HTMLElement>('.rv-arrow--next');
      const dotsContainer = carousel.querySelector<HTMLElement>('.rv-dots');
      if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) return;
      if (track.dataset.rvInit === 'true') return;
      track.dataset.rvInit = 'true';

      const slides = track.querySelectorAll<HTMLElement>('.rv-slide');
      const totalSlides = slides.length;
      const controls = carousel.querySelector<HTMLElement>('.rv-controls');
      let currentIndex = 0;
      let perView = getPerView();
      let autoplayTimer: ReturnType<typeof setInterval> | null = null;
      const abortController = new AbortController();
      const signal = abortController.signal;

      function getPerView(): number {
        if (window.innerWidth <= 640) return 1;
        if (window.innerWidth <= 1024) return 2;
        if (window.innerWidth <= 1280) return 3;
        return 4;
      }

      const maxIndex = () => Math.max(0, totalSlides - perView);

      function syncControlsVisibility() {
        if (!controls) return;
        controls.style.display = maxIndex() > 0 ? '' : 'none';
      }

      function buildDots() {
        dotsContainer!.innerHTML = '';
        const count = maxIndex() + 1;
        if (count <= 1) return;
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.setAttribute('aria-label', `Go to review group ${i + 1}`);
          if (i === currentIndex) dot.classList.add('is-active');
          dot.addEventListener('click', () => { goTo(i); resetAutoplay(); });
          dotsContainer!.appendChild(dot);
        }
      }

      function updateDots() {
        dotsContainer!.querySelectorAll('button').forEach((d, i) =>
          d.classList.toggle('is-active', i === currentIndex)
        );
      }

      function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const slideWidth = slides[0].offsetWidth;
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        updateDots();
      }

      function next() { goTo(currentIndex >= maxIndex() ? 0 : currentIndex + 1); }
      function prev() { goTo(currentIndex <= 0 ? maxIndex() : currentIndex - 1); }

      function startAutoplay() {
        stopAutoplay();
        if (maxIndex() === 0) return;
        autoplayTimer = setInterval(next, 5000);
      }
      function stopAutoplay() {
        if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
      }
      function resetAutoplay() { startAutoplay(); }

      prevBtn.addEventListener('click', () => { prev(); resetAutoplay(); }, { signal });
      nextBtn.addEventListener('click', () => { next(); resetAutoplay(); }, { signal });

      // Drag / swipe
      let startX = 0, dragOffset = 0, isDragging = false, trackOffset = 0;

      viewport.addEventListener('mousedown', (e) => {
        isDragging = true; startX = e.clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        stopAutoplay();
        e.preventDefault();
      }, { signal });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        dragOffset = e.clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { signal });
      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
        resetAutoplay();
      }, { signal });

      viewport.addEventListener('touchstart', (e) => {
        isDragging = true; startX = e.touches[0].clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        stopAutoplay();
      }, { passive: true, signal });
      viewport.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        dragOffset = e.touches[0].clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { passive: true, signal });
      viewport.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
        resetAutoplay();
      }, { passive: true, signal });

      // Pause on hover
      carousel.addEventListener('mouseenter', stopAutoplay, { signal });
      carousel.addEventListener('mouseleave', startAutoplay, { signal });

      // Resize
      window.addEventListener('resize', () => {
        perView = getPerView();
        buildDots();
        syncControlsVisibility();
        goTo(Math.min(currentIndex, maxIndex()));
        startAutoplay();
      }, { signal });

      // Clean up on page transition
      document.addEventListener('astro:before-swap', () => {
        stopAutoplay();
        abortController.abort();
      }, { once: true });

      buildDots();
      syncControlsVisibility();
      goTo(0);
      startAutoplay();
    });
  }

  initReviewsCarousel();
  document.addEventListener('astro:page-load', initReviewsCarousel);
</script>
