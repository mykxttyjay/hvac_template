---
import { getLocationText } from "@/config/site"

interface Review {
  name: string;
  time: string;
  content: string;
  readMoreHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  reviews: Review[];
}

const { badge = "GOOGLE REVIEW", title: rawTitle, description: rawDescription, reviews: rawReviews } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const reviews = rawReviews.map(r => ({ ...r, content: getLocationText(r.content) }));
---

<section class="rv-section" style="background-image: url('/images/map.png'); background-size: cover; background-position: center; background-attachment: fixed;">
  <div class="rv-body">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">

      <!-- Header -->
      <div class="rv-header" data-animate="fade-up">
        <div class="rv-eyebrow">
          <svg class="rv-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          <span class="rv-eyebrow-text">{badge}</span>
        </div>

        <h2 class="rv-title">{title}</h2>
        {description && <p class="rv-desc" set:html={description} />}
      </div>

      <!-- Marquee Carousel -->
      <div class="rv-marquee" data-animate="fade-up" data-animate-delay="100">
        <div class="rv-marquee-track">
          {reviews.map((review) => (
            <div class="rv-marquee-item">
              <div class="rv-card group">
                <span class="rv-card-strip"></span>

                <div class="rv-card-inner">
                  <!-- Top: quote + stars -->
                  <div class="rv-card-top">
                    <div class="rv-quote" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                    </div>
                    <div class="rv-stars" role="img" aria-label="5 out of 5 stars">
                      {Array.from({ length: 5 }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" class="rv-star" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      ))}
                    </div>
                  </div>

                  <!-- Content -->
                  <p class="rv-content" set:html={review.content} />

                  <!-- Author -->
                  <div class="rv-author">
                    <div class="rv-avatar">
                      <span>{review.name.split(' ').map(n => n[0]).join('')}</span>
                    </div>
                    <div class="rv-author-info">
                      <span class="rv-name">{review.name}</span>
                      <span class="rv-date">{review.time}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
          {/* Duplicate items for infinite scroll */}
          {reviews.map((review) => (
            <div class="rv-marquee-item">
              <div class="rv-card group">
                <span class="rv-card-strip"></span>

                <div class="rv-card-inner">
                  <!-- Top: quote + stars -->
                  <div class="rv-card-top">
                    <div class="rv-quote" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                    </div>
                    <div class="rv-stars" role="img" aria-label="5 out of 5 stars">
                      {Array.from({ length: 5 }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" class="rv-star" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      ))}
                    </div>
                  </div>

                  <!-- Content -->
                  <p class="rv-content" set:html={review.content} />

                  <!-- Author -->
                  <div class="rv-author">
                    <div class="rv-avatar">
                      <span>{review.name.split(' ').map(n => n[0]).join('')}</span>
                    </div>
                    <div class="rv-author-info">
                      <span class="rv-name">{review.name}</span>
                      <span class="rv-date">{review.time}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rv-section {
    position: relative;
    background: var(--background);
  }

  .rv-body {
    background: rgba(255, 255, 255, 0.7);
    padding: 4rem 0 5rem;
    position: relative;
    z-index: 2;
  }

  /* ─── Header ─── */
  .rv-header {
    margin-bottom: 2.5rem;
    text-align: center;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .rv-eyebrow {
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .rv-fan-icon {
    width: 20px;
    height: 20px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .rv-eyebrow-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    background: none;
    border: none;
    margin: 0;
  }

  .rv-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .rv-title { font-size: 45px; }
  }

  .rv-desc {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Marquee ─── */
  .rv-marquee {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .rv-marquee-track {
    display: flex;
    gap: 1.25rem;
    animation: scroll-left 60s linear infinite;
    padding: 1rem 0;
  }

  .rv-marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 0.625rem));
    }
  }

  .rv-marquee-item {
    flex-shrink: 0;
    width: 380px;
    min-width: 380px;
  }

  @media (max-width: 1024px) {
    .rv-marquee-item {
      width: 320px;
      min-width: 320px;
    }
  }

  @media (max-width: 640px) {
    .rv-marquee-item {
      width: 280px;
      min-width: 280px;
    }
  }

  /* ─── Card ─── */
  .rv-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.18);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.35s ease;
    height: 100%;
  }
  .rv-card:hover {
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  .rv-card-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
    z-index: 1;
  }
  .rv-card:hover .rv-card-strip {
    height: 100%;
  }

  .rv-card-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 320px;
  }

  .rv-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .rv-quote {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-tertiary);
    border: 1px solid rgba(0,0,0,0.06);
    color: var(--brand-primary);
    transition: all 0.3s ease;
  }
  .rv-quote svg {
    width: 28px;
    height: 28px;
  }
  .rv-card:hover .rv-quote {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    color: #ffffff;
  }

  .rv-stars {
    display: flex;
    gap: 3px;
  }
  .rv-star {
    color: var(--brand-highlight);
  }

  .rv-content {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--brand-secondary);
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .rv-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .rv-avatar {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--brand-primary);
    color: var(--brand-highlight);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    border-radius: 50%;
    transition: all 0.3s ease;
  }
  .rv-card:hover .rv-avatar {
    background: var(--brand-highlight);
    color: #ffffff;
  }
  .rv-author-info { display: flex; flex-direction: column; }
  .rv-name {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
  }
  .rv-date {
    font-size: 0.75rem;
    color: var(--brand-secondary);
    letter-spacing: 0.05em;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .rv-body {
      padding: 3rem 0 4rem;
    }
  }
</style>

<script>
  // Marquee animation is handled by CSS
  // No JavaScript needed for infinite scroll
</script>
