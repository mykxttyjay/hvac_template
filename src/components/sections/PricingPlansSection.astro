---
import { getLocationText } from "@/config/site"

interface Plan {
  ribbon: string;
  ribbonColor?: "great" | "better" | "best";
  title: string;
  price: string;
  period?: string;
  features: string[];
}

interface Props {
  title: string;
  description: string;
  plans: Plan[];
}

const { title: rawTitle, description: rawDescription, plans } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);

const bestIndex = plans.findIndex(p => p.ribbonColor === "best");
---

<section class="pp-section" style="background-image: url('https://images.unsplash.com/photo-1615799998603-7c6270a45196?q=80&w=704&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'); background-size: cover; background-position: center; background-attachment: fixed;">
  <div class="absolute inset-0 bg-white/75"></div>
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-16 relative z-10">

    <!-- Header -->
    <div class="pp-header" data-animate="fade-up">
      <div class="pp-eyebrow">
        <svg class="pp-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        <span class="pp-eyebrow-text">Plans</span>
      </div>
      <h2 class="pp-title">{title}</h2>
      <div class="pp-divider"></div>
      <p class="pp-desc" set:html={description} />
    </div>

    <!-- Plans grid -->
    <div class="pp-grid" data-animate-stagger>
      {plans.map((plan, i) => (
        <div class:list={["pp-card group", { "pp-card--featured": i === bestIndex }]}>
          <span class="pp-card-accent"></span>

          {/* Ribbon */}
          <div class="pp-ribbon">
            <span class="pp-ribbon-text">{plan.ribbon}</span>
          </div>

          <div class="pp-card-inner">
            <h3 class="pp-plan-title">{plan.title}</h3>

            {/* Price */}
            <div class="pp-price-block">
              <span class="pp-price">{plan.price}</span>
              {plan.period && <span class="pp-period">{plan.period}</span>}
            </div>

            <div class="pp-sep"></div>

            {/* Features */}
            <ul class="pp-features">
              {plan.features.map((feature) => (
                <li class="pp-feature">
                  <span class="pp-feature-dot"></span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          <a href="#" class="pp-card-cta">Get Started</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pp-section {
    background: var(--background);
    position: relative;
    overflow: hidden;
  }

  /* ─── Header ─── */
  .pp-header {
    text-align: center;
    margin-bottom: 3.5rem;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }
  .pp-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .pp-fan-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .pp-eyebrow-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
  }
  .pp-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  @media (min-width: 768px) {
    .pp-title { font-size: 45px; }
  }
  .pp-divider {
    display: none;
  }
  .pp-desc {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--brand-secondary);
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ─── Grid ─── */
  .pp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 100%;
    margin: 0 auto;
    align-items: center;
  }

  /* Featured card lift */
  .pp-grid > .pp-card--featured {
    height: 500px;
  }

  .pp-grid > .pp-card:not(.pp-card--featured) {
    height: 450px;
  }

  @media (min-width: 768px) {
    .pp-grid > .pp-card--featured {
      transform: translateY(-1rem);
    }
    .pp-grid > .pp-card--featured:hover {
      transform: translateY(calc(-1rem - 4px));
    }
  }

  /* ─── Card ─── */
  .pp-card {
    position: relative;
    background: white;
    border: 2px solid rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: all 0.35s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 12px;
  }
  .pp-card:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 12px 32px rgba(244, 145, 29, 0.15);
  }

  /* Featured card */
  .pp-card--featured {
    border-color: var(--brand-highlight);
    box-shadow: 0 8px 32px rgba(244, 145, 29, 0.2);
    transform: translateY(-1rem);
  }
  .pp-card--featured:hover {
    box-shadow: 0 16px 40px rgba(244, 145, 29, 0.25);
    transform: translateY(calc(-1rem - 4px));
  }

  .pp-card-accent {
    display: none;
  }

  /* ─── Ribbon ─── */
  .pp-ribbon {
    position: absolute;
    top: 20px;
    right: -35px;
    width: 160px;
    padding: 0.4rem 0;
    background: var(--brand-highlight);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(45deg);
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
    z-index: 10;
  }
  .pp-ribbon::before {
    content: '';
    position: absolute;
    left: 0;
    top: 100%;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid rgba(0, 0, 0, 0.2);
  }
  .pp-ribbon::after {
    content: '';
    position: absolute;
    right: 0;
    top: 100%;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid rgba(0, 0, 0, 0.2);
  }
  .pp-ribbon-text {
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    text-align: center;
    white-space: nowrap;
  }

  .pp-card--featured .pp-ribbon {
    background: var(--brand-highlight);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
  }
  .pp-card--featured .pp-ribbon-text {
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* ─── Card Inner ─── */
  .pp-card-inner {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .pp-plan-title {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-primary);
    margin-bottom: 1.25rem;
  }

  /* ─── Price ─── */
  .pp-price-block {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .pp-price {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--brand-primary);
  }
  .pp-card--featured .pp-price {
    color: var(--brand-highlight);
  }
  .pp-period {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--brand-secondary);
  }

  /* ─── Separator ─── */
  .pp-sep {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin-bottom: 1.5rem;
  }

  /* ─── Features ─── */
  .pp-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex: 1;
  }
  .pp-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--brand-secondary);
    font-weight: 500;
  }
  .pp-feature-dot {
    width: 8px;
    height: 8px;
    background: var(--brand-highlight);
    flex-shrink: 0;
    margin-top: 0.5rem;
    border-radius: 50%;
  }

  /* ─── CTA Button ─── */
  .pp-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 3rem;
    background: var(--brand-highlight);
    color: white;
    font-weight: 800;
    font-size: 14px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    width: calc(100% - 4rem);
    margin: 0 2rem 2rem;
  }
  .pp-card-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
  }
  .pp-card:not(.pp-card--featured) .pp-card-cta {
    background: transparent;
    color: var(--brand-highlight);
    border: 2px solid var(--brand-highlight);
  }
  .pp-card:not(.pp-card--featured) .pp-card-cta:hover {
    background: var(--brand-primary);
    color: white;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .pp-grid {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
  }
</style>
