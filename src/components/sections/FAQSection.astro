---
import { getLocationText } from "@/config/site"

interface FAQItem {
  question: string;
  answer?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  faqs: FAQItem[];
}

const { title: rawTitle, subtitle: rawSubtitle, badge = "FAQ", faqs: rawFaqs } = Astro.props;

const title = getLocationText(rawTitle);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const faqs = rawFaqs.map(faq => ({
  ...faq,
  question: getLocationText(faq.question),
  answer: faq.answer ? getLocationText(faq.answer) : undefined,
}));
---

<section class="fq-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Two-column layout -->
    <div class="fq-layout">

      <!-- Left: header + side panel -->
      <div class="fq-left">
        <div class="fq-header" data-animate="fade-up">
          <div class="fq-eyebrow">
            <span class="fq-eyebrow-text">{badge}</span>
          </div>
          <h2 class="fq-title">{title}</h2>
          <div class="fq-divider"></div>
          {subtitle && <p class="fq-subtitle">{subtitle}</p>}
        </div>

        <!-- Side card -->
        <div class="fq-side" data-animate="fade-up" data-animate-delay="200">
          <div class="fq-side-card">
            <span class="fq-side-accent"></span>
            <div class="fq-side-inner">
              <div class="fq-side-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
                  <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
              </div>
              <h3 class="fq-side-heading">Have Questions?</h3>
              <p class="fq-side-text">
                We're here to help. If you don't find your answer below, reach out to our team directly.
              </p>
              <a href="/contact" class="fq-side-btn">
                Contact Us
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: accordion -->
      <div class="fq-accordion" data-animate-stagger>
        {faqs.filter(faq => faq.question && faq.answer).map((faq, index) => (
          <div class="fq-item group">
            <button
              class="fq-trigger"
              aria-expanded="false"
              aria-controls={`fq-panel-${index}`}
              id={`fq-btn-${index}`}
            >
              <span class="fq-number">{String(index + 1).padStart(2, '0')}</span>
              <span class="fq-question">{faq.question}</span>
              <span class="fq-chevron">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </span>
            </button>
            <div
              class="fq-panel"
              id={`fq-panel-${index}`}
              role="region"
              aria-labelledby={`fq-btn-${index}`}
            >
              <div class="fq-answer" set:html={faq.answer} />
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  function initFAQ() {
    document.querySelectorAll<HTMLElement>('.fq-item').forEach((item) => {
      const trigger = item.querySelector<HTMLButtonElement>('.fq-trigger');
      if (!trigger) return;
      if (trigger.dataset.init === 'true') return;
      trigger.dataset.init = 'true';

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll<HTMLElement>('.fq-item').forEach((other) => {
          const otherTrigger = other.querySelector<HTMLButtonElement>('.fq-trigger');
          if (otherTrigger && other !== item) {
            otherTrigger.setAttribute('aria-expanded', 'false');
            other.classList.remove('is-open');
          }
        });

        // Toggle current
        if (isOpen) {
          trigger.setAttribute('aria-expanded', 'false');
          item.classList.remove('is-open');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          item.classList.add('is-open');
        }
      });
    });
  }

  initFAQ();
  document.addEventListener('astro:page-load', initFAQ);
</script>

<style>
  .fq-section {
    background: var(--background);
  }

  /* ─── Layout ─── */
  .fq-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }

  /* ─── Left Column ─── */
  .fq-left {
    position: sticky;
    top: 6rem;
  }

  /* ─── Header ─── */
  .fq-header {
    margin-bottom: 2rem;
  }
  .fq-eyebrow {
    margin-bottom: 1.25rem;
  }
  .fq-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }
  .fq-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .fq-title { font-size: 2.25rem; }
  }
  .fq-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin-bottom: 1.25rem;
  }
  .fq-subtitle {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Side Card ─── */
  .fq-side-card {
    position: relative;
    background: var(--brand-primary);
    overflow: hidden;
    transition: all 0.35s ease;
  }
  .fq-side-card:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
  }

  .fq-side-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--brand-highlight);
  }

  .fq-side-inner {
    padding: 2rem 1.5rem;
  }

  .fq-side-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--brand-highlight);
    margin-bottom: 1.25rem;
  }

  .fq-side-heading {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }
  .fq-side-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 1.5rem;
  }
  .fq-side-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.7rem 1.5rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-weight: 700;
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .fq-side-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .fq-side-btn svg {
    transition: transform 0.3s ease;
  }
  .fq-side-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Accordion ─── */
  .fq-accordion {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fq-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: border-color 0.3s ease;
    position: relative;
  }
  .fq-item:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .fq-item.is-open {
    border-bottom-color: var(--brand-highlight);
  }

  /* Left accent bar on open */
  .fq-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--brand-highlight);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s ease;
  }
  .fq-item.is-open::before {
    transform: scaleY(1);
  }

  .fq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }
  .fq-trigger:hover {
    background: var(--brand-tertiary);
  }

  .fq-number {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--brand-highlight);
    background: var(--brand-primary);
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fq-question {
    flex: 1;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-primary);
    line-height: 1.35;
  }

  .fq-chevron {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    background: var(--brand-tertiary);
    border: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--brand-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .fq-item.is-open .fq-chevron {
    background: var(--brand-primary);
    border-color: var(--brand-primary);
    color: var(--brand-highlight);
    transform: rotate(45deg);
  }

  /* Panel */
  .fq-panel {
    display: none;
  }
  .fq-item.is-open .fq-panel {
    display: block;
  }

  .fq-answer {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--brand-secondary);
    padding: 0 1.5rem 1.5rem 4.5rem;
  }
  .fq-answer :global(p:last-child) {
    margin-bottom: 0;
  }
  .fq-answer :global(p:first-child) {
    margin-top: 0;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .fq-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .fq-left {
      position: static;
    }
    .fq-trigger {
      padding: 1rem 1.25rem;
    }
    .fq-answer {
      padding-left: 1.25rem;
    }
  }
</style>
