---
interface IncludedItem {
  title: string;
  description: string;
  image?: string;
}

interface Props {
  title: string;
  description: string;
  includedItems: IncludedItem[];
  benefits: string[];
  buttonText?: string;
  buttonHref?: string;
  eyebrow?: string;
}

const { title, description, includedItems, benefits, buttonText = "VIEW PLANS", buttonHref = "/maintenance-plans", eyebrow } = Astro.props;
---

<section class="mp-section relative overflow-hidden bg-brand-primary">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10 pt-12 md:pt-16 pb-12 md:pb-16">
    <!-- Header -->
    <div class="mp-header" data-animate="fade-scale">
      {eyebrow && (
        <div class="mp-eyebrow">
          <svg class="mp-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          <span class="mp-eyebrow-text">{eyebrow}</span>
        </div>
      )}
      <h2 class="mp-title">{title}</h2>
      <p class="mp-desc" set:html={description} />
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12" data-animate-stagger>
      {includedItems.map((item, index) => {
        const icons = [
          `<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
           <circle cx="12" cy="12" r="3"/>`,
          `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
          `<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>`,
          `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`
        ];

        return (
          <div class="mp-card group">
            <span class="mp-card-accent"></span>
            {item.image && (
              <div class="mp-card-image">
                <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
              </div>
            )}
            <div class="mp-card-inner">
              <div class="mp-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={icons[index]} />
                </svg>
              </div>
              <h3 class="mp-card-title">{item.title}</h3>
              <p class="mp-card-desc" set:html={item.description} />
              <a href={buttonHref} class="mp-card-link" aria-label={`View details about ${item.title}`}>
                View Details
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="text-center" data-animate="fade-up">
      <a href={buttonHref} class="mp-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .mp-section {
    background: var(--brand-primary);
  }

  .mp-slope {
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* ─── Header ─── */
  .mp-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .mp-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }
  .mp-line {
    width: 60px;
    height: 3px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .mp-fan-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .mp-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    border: none;
    margin: 0;
  }

  .mp-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .mp-title { font-size: 45px; }
  }

  .mp-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }

  .mp-desc {
    font-size: 18px;
    line-height: 1.75;
    color: rgba(255,255,255,0.75);
  }

  /* ─── Cards ─── */
  .mp-card {
    position: relative;
    background: rgba(255,255,255,0.12);
    border: 2px solid rgba(244, 145, 29, 0.3);
    overflow: hidden;
    transition: all 0.35s ease;
    border-radius: 12px;
  }
  .mp-card:hover {
    background: rgba(255,255,255,0.18);
    border-color: var(--brand-highlight);
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(244, 145, 29, 0.2);
  }

  .mp-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--brand-highlight);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }
  .mp-card:hover .mp-card-accent {
    transform: scaleX(1);
  }

  .mp-card-inner {
    padding: 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 260px;
  }

  .mp-card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    margin: -2px -2px 1.5rem -2px;
  }

  .mp-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .mp-card:hover .mp-card-image img {
    transform: scale(1.08);
  }

  .mp-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(244, 145, 29, 0.15);
    border: 2px solid rgba(244, 145, 29, 0.4);
    color: var(--brand-highlight);
    margin-bottom: 1.25rem;
    transition: all 0.3s ease;
    border-radius: 8px;
  }
  .mp-card:hover .mp-icon {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    color: var(--brand-primary);
    transform: scale(1.1);
  }

  .mp-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }

  .mp-card-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin-bottom: auto;
    padding-bottom: 1.5rem;
  }

  .mp-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .mp-card-link:hover,
  .mp-card:hover .mp-card-link {
    color: var(--brand-highlight);
  }
  .mp-card-link svg {
    transition: transform 0.3s ease;
  }
  .mp-card:hover .mp-card-link svg {
    transform: translateX(4px);
  }

  /* ─── CTA ─── */
  .mp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.8rem 2rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .mp-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .mp-btn svg {
    transition: transform 0.3s ease;
  }
  .mp-btn:hover svg {
    transform: translateX(4px);
  }
</style>
