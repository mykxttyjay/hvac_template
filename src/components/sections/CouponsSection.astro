---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface Coupon {
  icon?: string;
  label: string;
  discount: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

interface Props {
  title?: string;
  coupons: Coupon[];
  backgroundImage?: string;
}

const {
  title: rawTitle = "Specials and Offers",
  coupons,
  backgroundImage,
} = Astro.props;

const title = getLocationText(rawTitle);
const centerIndex = Math.floor(coupons.length / 2);

const defaultBackgrounds = [
  'https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=800&q=80',
  'https://images.unsplash.com/photo-1650551182956-47efa0f90b64?w=800&q=80',
  'https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=800&q=80'
];
---

<section class="cpn-section relative overflow-hidden py-12 md:py-16 pb-20 md:pb-28">
  <div class="cpn-bg-base"></div>

  <div class="relative z-[1] container mx-auto px-6 md:px-12 lg:px-16">
    <!-- Section header -->
    <div class="mb-12 text-center" data-animate="fade-scale">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="h-[3px] w-10 bg-brand-highlight"></div>
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-brand-highlight">Limited Time</span>
        <div class="h-[3px] w-10 bg-brand-highlight"></div>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold uppercase tracking-tight text-brand-primary">{title}</h2>
    </div>

    <!-- Coupons grid -->
    <div class="cpn-grid" data-animate-stagger>
      {coupons.map((coupon, i) => {
        const cardBg = coupon.backgroundImage || (i === centerIndex && backgroundImage) || defaultBackgrounds[i % defaultBackgrounds.length];
        return (
          <div class:list={["cpn-coupon group", { "cpn-coupon--featured": i === centerIndex }]}>
            <!-- Top: image strip -->
            <div class="cpn-img-strip">
              <div class="cpn-img-bg">
                <Image
                  src={cardBg}
                  alt={coupon.label}
                  class="cpn-img-bg-actual"
                  width={600}
                  height={360}
                  format="webp"
                  quality={60}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="cpn-img-overlay"></div>
              <div class="cpn-img-content">
                <span class="cpn-tag">{coupon.label}</span>
              </div>
              <!-- Corner ribbon for featured -->
              {i === centerIndex && (
                <div class="cpn-ribbon">
                  <span>Best Deal</span>
                </div>
              )}
            </div>

            <!-- Perforated tear line -->
            <div class="cpn-tear">
              <div class="cpn-tear-notch cpn-tear-notch--left"></div>
              <div class="cpn-tear-line"></div>
              <div class="cpn-tear-notch cpn-tear-notch--right"></div>
            </div>

            <!-- Bottom: coupon details -->
            <div class="cpn-details">
              <div class="cpn-discount-row">
                <span class="cpn-discount">{coupon.discount}</span>
              </div>
              <p class="cpn-desc">{coupon.description}</p>
              <div class="cpn-footer">
                <div class="cpn-dashed-border"></div>
                <a href={coupon.buttonHref || "/contact"} class="cpn-btn">
                  {coupon.buttonText || "GET OFFER"}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ─── Section Background ─── */
  .cpn-bg-base {
    position: absolute;
    inset: 0;
    background: var(--brand-primary);
  }

  /* Section header override for dark bg */
  .cpn-section h2 {
    color: #fff;
  }
  .cpn-section .text-brand-primary {
    color: #fff;
  }

  /* ─── Grid ─── */
  .cpn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 76rem;
    margin: 0 auto;
    align-items: end;
  }

  /* Make the middle card much bigger and push it down */
  .cpn-grid > :nth-child(2) {
    transform: translateY(2rem) scale(1.08);
  }
  .cpn-grid > :nth-child(2):hover {
    transform: translateY(calc(2rem - 6px)) scale(1.08);
  }
  
  /* Make left and right cards bigger too */
  .cpn-grid > :nth-child(1),
  .cpn-grid > :nth-child(3) {
    transform: scale(1.0);
  }
  .cpn-grid > :nth-child(1):hover,
  .cpn-grid > :nth-child(3):hover {
    transform: translateY(-6px) scale(1.0);
  }
  
  /* Increase image height for all cards */
  .cpn-img-strip {
    height: 200px;
  }
  
  /* Increase image height for center card */
  .cpn-grid > :nth-child(2) .cpn-img-strip {
    height: 220px;
  }
  
  /* Larger discount text for center card */
  .cpn-grid > :nth-child(2) .cpn-discount {
    font-size: 3.25rem;
  }
  
  /* Larger description for center card */
  .cpn-grid > :nth-child(2) .cpn-desc {
    font-size: 0.9rem;
  }

  /* ─── Coupon Card ─── */
  .cpn-coupon {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    border-radius: 0;
    overflow: hidden;
  }

  .cpn-coupon:hover {
    transform: translateY(-8px) rotate(-1deg);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
  }
  
  /* Orange dashed outline for 1st and 3rd cards */
  .cpn-grid > :nth-child(1),
  .cpn-grid > :nth-child(3) {
    border: 3px dashed var(--brand-highlight);
  }
  
  .cpn-grid > :nth-child(1):hover,
  .cpn-grid > :nth-child(3):hover {
    border-color: #ff9d2e;
  }

  /* Featured card */
  .cpn-coupon--featured {
    border: 4px solid var(--brand-highlight);
  }
  .cpn-coupon--featured:hover {
    border-color: #ff9d2e;
  }

  /* ─── Image Strip (top half) ─── */
  .cpn-img-strip {
    position: relative;
    height: 180px;
    overflow: hidden;
  }

  .cpn-img-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    transition: transform 0.6s ease;
  }
  .cpn-img-bg-actual {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(1.1) contrast(1.05);
  }
  .cpn-coupon:hover .cpn-img-bg {
    transform: scale(1.08);
  }

  .cpn-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--brand-primary) 50%, transparent) 0%,
      color-mix(in srgb, var(--brand-primary) 70%, transparent) 100%
    );
    z-index: 1;
  }

  .cpn-img-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    height: 100%;
    padding: 1.25rem 1.5rem;
  }

  .cpn-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand-highlight);
    border-bottom: 2px solid var(--brand-highlight);
    padding-bottom: 0.3rem;
  }

  /* Corner ribbon */
  .cpn-ribbon {
    position: absolute;
    top: 20px;
    right: -35px;
    z-index: 5;
    background: var(--brand-highlight);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.5rem 3rem;
    transform: rotate(45deg);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Perforated Tear Line ─── */
  .cpn-tear {
    position: relative;
    display: flex;
    align-items: center;
    height: 0;
    z-index: 3;
  }

  .cpn-tear-notch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--brand-primary);
    flex-shrink: 0;
    position: relative;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
  }
  .cpn-tear-notch--left {
    margin-left: -10px;
  }
  .cpn-tear-notch--right {
    margin-right: -10px;
  }

  .cpn-tear-line {
    flex: 1;
    border-top: 3px dashed rgba(244, 145, 29, 0.4);
    position: relative;
  }

  /* ─── Details (bottom half) ─── */
  .cpn-details {
    padding: 2rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    background: 
      linear-gradient(135deg, rgba(244, 145, 29, 0.05) 0%, transparent 50%),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(244, 145, 29, 0.03) 2px,
        rgba(244, 145, 29, 0.03) 4px
      );
    position: relative;
  }
  
  .cpn-details::before {
    content: 'COUPON';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-15deg);
    font-size: 6rem;
    font-weight: 900;
    color: rgba(244, 145, 29, 0.03);
    letter-spacing: 0.2em;
    pointer-events: none;
    z-index: 0;
  }
  
  .cpn-details > * {
    position: relative;
    z-index: 1;
  }

  .cpn-discount-row {
    margin-bottom: 0.5rem;
  }

  .cpn-discount {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 900;
    font-size: 3.5rem;
    line-height: 0.9;
    color: var(--brand-primary);
    text-transform: uppercase;
    text-shadow: 3px 3px 0px rgba(244, 145, 29, 0.2);
    position: relative;
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, rgba(244, 145, 29, 0.1) 0%, transparent 100%);
    border-left: 5px solid var(--brand-highlight);
    margin-bottom: 1rem;
  }

  .cpn-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: #666;
    margin-bottom: auto;
    padding-bottom: 1.25rem;
  }

  .cpn-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cpn-dashed-border {
    display: none;
  }

  .cpn-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    padding: 0.75rem 1.75rem;
    font-weight: 800;
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    align-self: flex-start;
  }
  .cpn-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .cpn-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cpn-grid {
      grid-template-columns: 1fr;
    }
    .cpn-grid > :nth-child(2) {
      transform: none;
    }
    .cpn-grid > :nth-child(2):hover {
      transform: translateY(-6px);
    }
    .cpn-img-strip {
      height: 150px;
    }
    .cpn-discount {
      font-size: 2.25rem;
    }
  }
</style>
