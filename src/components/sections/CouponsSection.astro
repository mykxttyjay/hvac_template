---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface Coupon {
  icon?: string;
  label: string;
  discount: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

interface Props {
  title?: string;
  coupons: Coupon[];
  backgroundImage?: string;
}

const {
  title: rawTitle = "Specials and Offers",
  coupons,
  backgroundImage,
} = Astro.props;

const title = getLocationText(rawTitle);
const centerIndex = Math.floor(coupons.length / 2);

const defaultBackgrounds = [
  'https://johnh967.sg-host.com/wp-content/uploads/2024/12/AC-Repair-Services.webp',
  'https://johnh967.sg-host.com/wp-content/uploads/sb-instagram-feed-images/466556611_1575760946412367_152571973762791733_nfull.webp',
  'https://johnh967.sg-host.com/wp-content/uploads/slider/cache/3208844a78ae424ec0bfef8623738be2/HVAC-Repair-Banner.webp'
];
---

<section class="cpn-section relative overflow-hidden py-20 md:py-28">
  <div class="cpn-bg-base"></div>

  <div class="relative z-[1] container mx-auto px-6 md:px-12 lg:px-16">
    <!-- Section header -->
    <div class="mb-14" data-animate="fade-scale">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[3px] w-10 bg-brand-highlight"></div>
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-brand-highlight">Limited Time</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold uppercase tracking-tight text-brand-primary">{title}</h2>
    </div>

    <!-- Coupons grid -->
    <div class="cpn-grid" data-animate-stagger>
      {coupons.map((coupon, i) => {
        const cardBg = coupon.backgroundImage || (i === centerIndex && backgroundImage) || defaultBackgrounds[i % defaultBackgrounds.length];
        return (
          <div class:list={["cpn-coupon group", { "cpn-coupon--featured": i === centerIndex }]}>
            <!-- Top: image strip -->
            <div class="cpn-img-strip">
              <div class="cpn-img-bg">
                <Image
                  src={cardBg}
                  alt={coupon.label}
                  class="cpn-img-bg-actual"
                  width={600}
                  height={360}
                  format="webp"
                  quality={60}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="cpn-img-overlay"></div>
              <div class="cpn-img-content">
                <span class="cpn-tag">{coupon.label}</span>
              </div>
              <!-- Corner ribbon for featured -->
              {i === centerIndex && (
                <div class="cpn-ribbon">
                  <span>Best Deal</span>
                </div>
              )}
            </div>

            <!-- Perforated tear line -->
            <div class="cpn-tear">
              <div class="cpn-tear-notch cpn-tear-notch--left"></div>
              <div class="cpn-tear-line"></div>
              <div class="cpn-tear-notch cpn-tear-notch--right"></div>
            </div>

            <!-- Bottom: coupon details -->
            <div class="cpn-details">
              <div class="cpn-discount-row">
                <span class="cpn-discount">{coupon.discount}</span>
              </div>
              <p class="cpn-desc">{coupon.description}</p>
              <div class="cpn-footer">
                <div class="cpn-dashed-border"></div>
                <a href={coupon.buttonHref || "/contact"} class="cpn-btn">
                  {coupon.buttonText || "GET OFFER"}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ─── Section Background ─── */
  .cpn-bg-base {
    position: absolute;
    inset: 0;
    background: var(--brand-primary);
  }

  /* Section header override for dark bg */
  .cpn-section h2 {
    color: #fff;
  }
  .cpn-section .text-brand-primary {
    color: #fff;
  }

  /* ─── Grid ─── */
  .cpn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 76rem;
    margin: 0 auto;
    align-items: end;
  }

  /* Lift the middle card */
  .cpn-grid > :nth-child(2) {
    transform: translateY(-1.5rem);
  }
  .cpn-grid > :nth-child(2):hover {
    transform: translateY(calc(-1.5rem - 6px));
  }

  /* ─── Coupon Card ─── */
  .cpn-coupon {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
  }

  .cpn-coupon:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }

  /* Featured card glow */
  .cpn-coupon--featured {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25), 0 0 0 2px var(--brand-highlight);
  }
  .cpn-coupon--featured:hover {
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35), 0 0 0 2px var(--brand-highlight), 0 0 30px color-mix(in srgb, var(--brand-highlight) 25%, transparent);
  }

  /* ─── Image Strip (top half) ─── */
  .cpn-img-strip {
    position: relative;
    height: 180px;
    overflow: hidden;
  }

  .cpn-img-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    transition: transform 0.6s ease;
  }
  .cpn-img-bg-actual {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cpn-coupon:hover .cpn-img-bg {
    transform: scale(1.08);
  }

  .cpn-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--brand-primary) 70%, transparent) 0%,
      color-mix(in srgb, var(--brand-primary) 90%, transparent) 100%
    );
    z-index: 1;
  }

  .cpn-img-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    height: 100%;
    padding: 1.25rem 1.5rem;
  }

  .cpn-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand-highlight);
    border-bottom: 2px solid var(--brand-highlight);
    padding-bottom: 0.3rem;
  }

  /* Corner ribbon */
  .cpn-ribbon {
    position: absolute;
    top: 16px;
    right: -32px;
    z-index: 5;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.3rem 2.5rem;
    transform: rotate(45deg);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  /* ─── Perforated Tear Line ─── */
  .cpn-tear {
    position: relative;
    display: flex;
    align-items: center;
    height: 0;
    z-index: 3;
  }

  .cpn-tear-notch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--brand-primary);
    flex-shrink: 0;
    position: relative;
  }
  .cpn-tear-notch--left {
    margin-left: -8px;
  }
  .cpn-tear-notch--right {
    margin-right: -8px;
  }

  .cpn-tear-line {
    flex: 1;
    border-top: 2px dashed color-mix(in srgb, var(--brand-primary) 15%, transparent);
  }

  /* ─── Details (bottom half) ─── */
  .cpn-details {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .cpn-discount-row {
    margin-bottom: 0.5rem;
  }

  .cpn-discount {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 2.75rem;
    line-height: 1;
    color: var(--brand-primary);
    text-transform: uppercase;
  }

  .cpn-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: #666;
    margin-bottom: auto;
    padding-bottom: 1.25rem;
  }

  .cpn-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cpn-dashed-border {
    border-top: 2px dashed color-mix(in srgb, var(--brand-primary) 12%, transparent);
    padding-top: 1rem;
  }

  .cpn-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    padding: 0.75rem 1.75rem;
    font-weight: 800;
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    align-self: flex-start;
  }
  .cpn-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .cpn-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cpn-grid {
      grid-template-columns: 1fr;
    }
    .cpn-grid > :nth-child(2) {
      transform: none;
    }
    .cpn-grid > :nth-child(2):hover {
      transform: translateY(-6px);
    }
    .cpn-img-strip {
      height: 150px;
    }
    .cpn-discount {
      font-size: 2.25rem;
    }
  }
</style>
