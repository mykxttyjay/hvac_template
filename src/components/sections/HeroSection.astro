---
import { Image } from "astro:assets";
import bg2Img from "/public/images/bg2.jpg";
import { getLocationText } from "@/config/site"

const defaultHeroImages = [
  "https://images.unsplash.com/photo-1647755881386-6b1f1347971c?q=80&w=1920&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  "https://images.unsplash.com/photo-1722131646940-b821a6cc6252?q=80&w=1920&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  "https://images.unsplash.com/photo-1650551182956-47efa0f90b64?q=80&w=1920&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
];

// Check if a URL is a remote image we can optimize via Astro
const isRemoteImage = (url: string) => url.startsWith('http://') || url.startsWith('https://');

interface Props {
  variant?: "slider" | "subpage";
  buttonHref?: string;
  showArrow?: boolean;
  // Slider-specific props
  images?: string[];
  // Subpage-specific props
  badge?: string;
  title?: string;
  subtitle?: string;
  buttonText?: string;
  image?: string;
  imageAlt?: string;
  trustIndicators?: string[];
}

const {
  variant = "slider",
  buttonHref = "#",
  showArrow = true,
  images,
  badge,
  title: subpageTitle,
  subtitle: subpageSubtitle,
  buttonText: subpageButtonText = "SCHEDULE SERVICE",
  image: subpageImage,
  imageAlt = "HVAC service",
  trustIndicators,
} = Astro.props;

const heroImages = images && images.length > 0 ? images : defaultHeroImages;

const slides = [
  {
    title: "Fast, Reliable, & Affordable Service",
    subtitle: "Need HVAC Repair or New Installation?\nWe've Got You Covered!",
    buttonText: "Schedule a Call",
    statNumber: "$99",
    statLabel: "Service Call",
    statDescription: "Expert Repairs & Installation included with every visit.",
    bgImage: heroImages[0 % heroImages.length],
    couponValue: "$99",
    couponLabel: "Service Call",
    couponSideLabel: "SAVE",
  },
  {
    title: "Flexible Financing Available",
    subtitle: "No Interest. No Payments. Until 2026!",
    buttonText: "Learn More",
    statNumber: "0%",
    statLabel: "Interest",
    statDescription: "With approved financing. Ask us about our flexible plans.",
    bgImage: heroImages[1 % heroImages.length],
    couponValue: "0%",
    couponLabel: "Interest",
    couponSideLabel: "DEAL",
  },
  {
    title: "Limited Time Offer — Don't Miss Out!",
    subtitle: "Furnace Tune-Up Special! Only $95 with Coupon!",
    buttonText: "Call Now",
    statNumber: "1yr",
    statLabel: "Warranty",
    statDescription: "Warranty on furnace repair. Expert maintenance for peak efficiency.",
    bgImage: heroImages[2 % heroImages.length],
    couponValue: "$95",
    couponLabel: "Tune-Up",
    couponSideLabel: "PROMO",
  },
];

const isSlider = variant === "slider";
---

{isSlider ? (
<section class="hero-section relative w-full overflow-hidden">
  <!-- Background images -->
  {slides.map((slide, i) => (
    <div class={`hero-bg absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-bg={i}>
      {isRemoteImage(slide.bgImage) ? (
        <Image
          src={slide.bgImage}
          alt="HVAC background"
          class="absolute inset-0 w-full h-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "auto"}
          decoding={i === 0 ? "sync" : "async"}
          width={1920}
          height={1080}
          widths={[640, 768, 1024, 1280, 1536, 1920]}
          sizes="100vw"
          format="webp"
          quality={80}
        />
      ) : (
        <img
          src={slide.bgImage}
          alt="HVAC background"
          class="absolute inset-0 w-full h-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "auto"}
          decoding={i === 0 ? "sync" : "async"}
          width="1920"
          height="1080"
        />
      )}
    </div>
  ))}

  <!-- Blue to transparent gradient (90 degree angle) -->
  <div class="hero-slope absolute inset-0 z-[1]">
    <svg class="h-full w-full" viewBox="0 0 1440 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="blueGradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:var(--brand-primary);stop-opacity:1" />
          <stop offset="70%" style="stop-color:var(--brand-primary);stop-opacity:0.5" />
          <stop offset="100%" style="stop-color:var(--brand-primary);stop-opacity:0" />
        </linearGradient>
      </defs>
      <rect x="0" y="0" width="1440" height="800" fill="url(#blueGradient)" />
    </svg>
  </div>

  <!-- Content — centered vertically -->
  <div class="relative z-[2] container mx-auto px-6 md:px-12 lg:px-16 flex items-center min-h-[85vh]">
    <div class="hero-content max-w-xl">

      <!-- Slides -->
      <div class="slides-container relative">
        {slides.map((slide, i) => (
          <div
            class={`hero-slide ${i === 0 ? 'active' : ''}`}
            data-slide={i}
          >
            <!-- Title with coupon -->
            <div class="hero-title-wrapper">
              <h1 class="hero-title text-[2.2rem] md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] mb-5 uppercase tracking-tight">
                {getLocationText(slide.title)}
              </h1>
              
              <!-- Simple coupon card -->
              <div class="hero-coupon-card">
                <div class="coupon-content">
                  <div class="coupon-value">{slide.couponValue}</div>
                  <div class="coupon-label-text">{slide.couponLabel}</div>
                </div>
                <div class="coupon-side">
                  <span class="coupon-label">{slide.couponSideLabel}</span>
                </div>
              </div>
            </div>

            <!-- Subtitle (small, muted, below title) -->
            <p class="hero-subtitle text-xs md:text-sm leading-relaxed max-w-sm">
              {slide.subtitle}
            </p>
          </div>
        ))}
      </div>

      <!-- Dots below content -->
      <div class="flex items-center gap-3 mt-8">
        {slides.map((_, i) => (
          <button
            class={`hero-dot transition-all duration-300 ${i === 0 ? 'active' : ''}`}
            data-index={i}
            aria-label={`Slide ${i + 1}`}
          />
        ))}
        <div class="progress-track ml-3 w-16 h-0.5 bg-gray-300 rounded-full overflow-hidden">
          <div class="progress-fill h-full rounded-full"></div>
        </div>
      </div>
    </div>
  </div>
</section>
) : (
<!-- SUBPAGE VARIANT -->
<section class="hero-section relative w-full overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    {subpageImage && isRemoteImage(subpageImage) ? (
      <Image
        src={subpageImage}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width={1920}
        height={1080}
        widths={[640, 768, 1024, 1280, 1536, 1920]}
        sizes="100vw"
        format="webp"
        quality={80}
      />
    ) : subpageImage ? (
      <img
        src={subpageImage}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        width="1920"
        height="1080"
      />
    ) : (
      <Image
        src={bg2Img}
        alt="HVAC background"
        widths={[640, 768, 1024, 1280, 1536, 1920]}
        sizes="100vw"
        format="webp"
        quality={80}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    )}
  </div>

  <!-- Blue to transparent gradient (90 degree angle) -->
  <div class="hero-slope absolute inset-0 z-[1]">
    <svg class="h-full w-full" viewBox="0 0 1440 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="blueGradientSubpage" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:var(--brand-primary);stop-opacity:1" />
          <stop offset="70%" style="stop-color:var(--brand-primary);stop-opacity:0.5" />
          <stop offset="100%" style="stop-color:var(--brand-primary);stop-opacity:0" />
        </linearGradient>
      </defs>
      <rect x="0" y="0" width="1440" height="800" fill="url(#blueGradientSubpage)" />
    </svg>
  </div>

  <!-- Content — centered vertically -->
  <div class="relative z-[2] container mx-auto px-6 md:px-12 lg:px-16 flex items-center min-h-[85vh]">
    <div class="hero-content max-w-xl">

      {badge && (
        <div class="mb-5">
          <span class="hero-eyebrow text-[11px] md:text-xs font-semibold tracking-[0.18em] uppercase text-brand-highlight inline-block pb-2 border-b-2 border-brand-highlight">
            {getLocationText(badge)}
          </span>
        </div>
      )}

      <h1 class="hero-title text-[2.2rem] md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] mb-5 uppercase tracking-tight">
        {subpageTitle && getLocationText(subpageTitle)}
      </h1>

      {subpageSubtitle && (
        <p class="hero-subtitle text-xs md:text-sm leading-relaxed max-w-sm">
          {getLocationText(subpageSubtitle)}
        </p>
      )}

      {trustIndicators && trustIndicators.length > 0 && (
        <div class="flex flex-wrap gap-4 mt-6">
          {trustIndicators.map((indicator) => (
            <span class="inline-flex items-center gap-2 text-sm text-white">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-highlight" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              {getLocationText(indicator)}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
)}

<style>
  .hero-section {
    min-height: 85vh;
    background: #f5f5f5;
  }

  /* The slope SVG layer */
  .hero-slope {
    pointer-events: none;
  }

  /* Title & subtitle sit on blue gradient — white text */
  .hero-title {
    color: #ffffff;
    line-height: 1.05;
    font-size: 2.2rem;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 3.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 75px;
    }
  }

  .hero-subtitle {
    color: #ffffff;
    font-size: 14px;
    white-space: normal;
    opacity: 0.95;
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: 18px;
      white-space: nowrap;
    }
  }

  /* CTA button */
  .hero-cta {
    background: var(--brand-highlight);
    color: #ffffff;
    position: relative;
    overflow: hidden;
  }

  .hero-cta:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }

  /* Coupon ticket */
  .hero-title-wrapper {
    position: relative;
    display: inline-block;
  }

  .hero-coupon-card {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: white;
    border: 2px dashed var(--brand-primary);
    border-radius: 12px;
    overflow: hidden;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 12px 32px rgba(30, 58, 95, 0.25), 0 0 0 1px rgba(30, 58, 95, 0.1);
    animation: slideInRight 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    max-width: 300px;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-coupon-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(30, 58, 95, 0.3), 0 0 0 1px rgba(30, 58, 95, 0.15);
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Main content area */
  .coupon-content {
    flex: 1;
    background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
    padding: 1.5rem 2.0rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .coupon-content::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--brand-highlight) 0%, var(--brand-primary) 50%, var(--brand-highlight) 100%);
    opacity: 0.6;
  }

  .coupon-value {
    font-weight: 900;
    font-size: 3.5rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: linear-gradient(135deg, var(--brand-primary) 0%, #1a2f4a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    font-family: 'Arial Black', sans-serif;
  }

  .coupon-label-text {
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand-primary);
    opacity: 0.75;
  }

  /* Side coupon label */
  .coupon-side {
    background: linear-gradient(135deg, var(--brand-primary) 0%, #1a2f4a 100%);
    color: white;
    padding: 1.75rem 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 75px;
    position: relative;
    z-index: 1;
    box-shadow: inset -2px 0 8px rgba(0, 0, 0, 0.1);
  }

  .coupon-label {
    font-weight: 900;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    position: relative;
    z-index: 2;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .hero-coupon-card {
      max-width: 100%;
      margin-top: 1rem;
    }

    .coupon-content {
      padding: 1.5rem 1.75rem;
    }

    .coupon-value {
      font-size: 2.8rem;
    }

    .coupon-label-text {
      font-size: 0.75rem;
    }

    .coupon-side {
      padding: 1.5rem 0.65rem;
      min-width: 65px;
    }

    .coupon-label {
      font-size: 0.8rem;
    }
  }

  /* Slides */
  .slides-container {
    position: relative;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
  }

  .hero-slide.active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Navigation dots — white inactive, orange active */
  .hero-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .hero-dot:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  .hero-dot.active {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    box-shadow: 0 0 6px color-mix(in srgb, var(--brand-highlight) 40%, transparent);
  }

  /* Progress bar */
  .progress-fill {
    background: var(--brand-highlight);
    width: 0%;
    transition: width linear;
  }

  /* Entrance animation */
  .hero-content {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll indicator bounce */
  .scroll-hint {
    animation: subtleBounce 2s ease-in-out infinite;
  }

  @keyframes subtleBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: 70vh;
    }

    /* On mobile, make slope cover more so text is always on white */
    .hero-slope svg polygon:first-child {
      points: 0,0 1440,0 1200,800 0,800;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content {
      animation: none;
    }
    .scroll-hint {
      animation: none;
    }
    .hero-slide {
      transition: opacity 0.3s ease;
      transform: none !important;
    }
  }
</style>

<script is:inline>
  var HERO_INTERVAL = 5000;
  var heroTimer;

  function initHeroSlider() {
    if (heroTimer) {
      clearInterval(heroTimer);
      heroTimer = undefined;
    }

    var slides = document.querySelectorAll('.hero-slide');
    var dots = document.querySelectorAll('.hero-dot');
    var bgs = document.querySelectorAll('.hero-bg');
    var fill = document.querySelector('.progress-fill');
    if (!slides.length || !dots.length) return;

    var current = 0;

    function goTo(index) {
      slides[current].classList.remove('active');
      slides[current].style.position = 'absolute';
      slides[current].style.width = '100%';
      dots[current].classList.remove('active');
      if (bgs[current]) bgs[current].classList.replace('opacity-100', 'opacity-0');

      current = index;

      slides[current].classList.add('active');
      slides[current].style.position = '';
      slides[current].style.width = '';
      dots[current].classList.add('active');
      if (bgs[current]) bgs[current].classList.replace('opacity-0', 'opacity-100');

      startProgress();
    }

    function startProgress() {
      if (fill) {
        fill.style.transition = 'none';
        fill.style.width = '0%';
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            fill.style.transition = 'width ' + HERO_INTERVAL + 'ms linear';
            fill.style.width = '100%';
          });
        });
      }
      if (heroTimer) clearInterval(heroTimer);
      heroTimer = setInterval(function() { goTo((current + 1) % slides.length); }, HERO_INTERVAL);
    }

    dots.forEach(function(dot, i) { dot.addEventListener('click', function() { goTo(i); }); });
    startProgress();
  }

  initHeroSlider();
  document.addEventListener('astro:page-load', initHeroSlider);
</script>
