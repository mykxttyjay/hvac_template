---
interface ServiceCard {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: ServiceCard[];
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { badge = "OUR SERVICES", title, description, categories } = Astro.props;
---

<section class="relative bg-gradient-to-b from-gray-50 to-white overflow-hidden py-24 md:py-32">
  {/* Background decorative elements */}
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[800px] bg-brand-primary/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/4 w-[600px] h-[600px] bg-brand-highlight/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    <!-- Header -->
    <div class="mb-16 max-w-4xl" data-animate="fade-up">
      <div class="mb-6">
        <span class="inline-block px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-brand-highlight bg-brand-primary rounded-full shadow-sm">
          {badge}
        </span>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <h2 class="text-4xl md:text-5xl lg:text-[45px] font-extrabold uppercase tracking-tight leading-[1.1] text-brand-primary">
          {title}
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-gray-600" set:html={description} />
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 sm:gap-4 mb-12 border-b border-gray-200 pb-2 svc-tabs" data-animate="fade-up" data-animate-delay="100">
      {categories.map((category, index) => (
        <button
          class="svc-tab group relative px-6 py-3 text-sm font-bold uppercase tracking-wider rounded-full transition-all duration-300 overflow-hidden"
          data-tab={index}
          data-active={index === 0 ? "true" : "false"}
        >
          <span class="absolute inset-0 w-full h-full bg-brand-primary scale-0 opacity-0 transition-all duration-300 group-data-[active=true]:scale-100 group-data-[active=true]:opacity-100 rounded-full"></span>
          <span class="relative z-10 text-gray-500 group-hover:text-brand-primary group-data-[active=true]:text-white transition-colors duration-300">
            {category.title}
          </span>
        </button>
      ))}
    </div>

    <!-- Service Cards Grid -->
    <div class="relative min-h-[800px] sm:min-h-[600px] lg:min-h-[400px]">
      {categories.map((category, catIndex) => (
        <div
          class="service-content absolute inset-0 transition-all duration-500 transform"
          data-content={catIndex}
          style={catIndex === 0 ? "opacity: 1; pointer-events: auto; transform: translateY(0);" : "opacity: 0; pointer-events: none; transform: translateY(20px);"}
        >
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate-stagger>
            {category.services.map((service, serviceIndex) => {
              const Tag = service.href ? 'a' : 'div';
              return (
                <Tag
                  {...(service.href ? { href: service.href } : {})}
                  class="group relative bg-white border border-gray-100 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] flex flex-col h-full"
                  style={`transition-delay: ${serviceIndex * 70}ms`}
                >
                  {/* Highlight strip top */}
                  <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-brand-primary to-brand-highlight transform origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"></div>

                  <div class="p-8 flex-1 flex flex-col">
                    <div class="w-14 h-14 rounded-xl flex items-center justify-center bg-gray-50 border border-gray-100 text-brand-primary mb-6 transition-all duration-300 group-hover:bg-brand-primary group-hover:text-brand-highlight group-hover:-translate-y-1 group-hover:shadow-lg">
                      <span class="[&>svg]:w-7 [&>svg]:h-7" set:html={service.icon} />
                    </div>

                    <h3 class="text-lg font-bold text-gray-900 mb-3 leading-snug group-hover:text-brand-primary transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-sm text-gray-500 leading-relaxed mb-6 flex-1" set:html={service.description} />

                    {service.href && (
                      <div class="mt-auto flex items-center justify-between border-t border-gray-100 pt-5">
                        <span class="text-xs font-bold uppercase tracking-widest text-gray-400 group-hover:text-brand-primary transition-colors">Learn More</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 transition-all duration-300 group-hover:bg-brand-highlight group-hover:text-brand-primary group-hover:scale-110">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                          </svg>
                        </div>
                      </div>
                    )}
                  </div>
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('.svc-tab');
  const contents = document.querySelectorAll<HTMLElement>('.service-content');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const tabIndex = tab.getAttribute('data-tab');

      tabs.forEach((t) => t.setAttribute('data-active', 'false'));
      tab.setAttribute('data-active', 'true');

      contents.forEach((content) => {
        const contentIndex = content.getAttribute('data-content');
        if (contentIndex === tabIndex) {
          content.style.opacity = '1';
          content.style.pointerEvents = 'auto';
          content.style.transform = 'translateY(0)';
        } else {
          content.style.opacity = '0';
          content.style.pointerEvents = 'none';
          content.style.transform = 'translateY(20px)';
        }
      });
    });
  });
</script>
      });
    });
  });


</script>
