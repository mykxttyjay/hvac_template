---
import { Image } from "astro:assets";
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
  backgroundImage?: string;
  trustIndicators?: string[];
}

const {
  title: rawTitle,
  subtitle: rawSubtitle,
  buttonText = "Get a Quote",
  buttonHref = "/contact",
  image = "/images/bg2.jpg",
  imageAlt = "Service background",
  backgroundImage,
  trustIndicators: rawTrustIndicators = [],
} = Astro.props;

const title = getLocationText(rawTitle);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const trustIndicators = rawTrustIndicators.map(getLocationText);
const bgSrc = backgroundImage || image;
const isRemoteImage = bgSrc.startsWith('http://') || bgSrc.startsWith('https://');
---

<section class="hp-hero">
  <!-- Top highlight bar -->
  <div class="hp-bar"></div>

  <!-- Background image -->
  <div class="hp-bg">
    {isRemoteImage ? (
      <Image
        src={bgSrc}
        alt={imageAlt}
        class="hp-bg-img"
        loading="eager"
        fetchpriority="high"
        width={1440}
        height={810}
        widths={[480, 768, 1280, 1440]}
        sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, (max-width: 1280px) 1280px, 1440px"
        format="webp"
        quality={65}
      />
    ) : (
      <img
        src={bgSrc}
        alt={imageAlt}
        class="hp-bg-img"
        loading="eager"
        fetchpriority="high"
        width="1440"
        height="810"
      />
    )}
    <div class="hp-overlay"></div>
  </div>

  <!-- Content -->
  <div class="hp-content">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="hp-inner">

        <!-- Left: text -->
        <div class="hp-text">
          <!-- Eyebrow -->
          {subtitle && (
            <div class="hp-eyebrow-wrap" data-animate="fade-up">
              <div class="hp-eyebrow-line"></div>
              <span class="hp-eyebrow">{subtitle}</span>
            </div>
          )}

          <h1 class="hp-title" data-animate="fade-up" data-animate-delay="100">{title}</h1>

          <!-- Trust indicators -->
          {trustIndicators.length > 0 && (
            <div class="hp-trust" data-animate="fade-up" data-animate-delay="200">
              {trustIndicators.map((item) => (
                <span class="hp-trust-item">
                  <svg xmlns="http://www.w3.org/2000/svg" class="hp-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  {item}
                </span>
              ))}
            </div>
          )}

          <!-- CTAs -->
          <div class="hp-actions" data-animate="fade-up" data-animate-delay="300">
            <a href={buttonHref} class="hp-btn hp-btn-highlight">
              {buttonText}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href={`tel:${siteConfig.contact.phone}`} class="hp-btn hp-btn-outline">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
              {siteConfig.contact.phoneFormatted}
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .hp-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Top highlight bar */
  .hp-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--brand-highlight);
    z-index: 10;
  }

  /* ─── Background ─── */
  .hp-bg {
    position: absolute;
    inset: 0;
  }
  .hp-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3);
  }
  .hp-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(5, 3, 21, 0.88) 0%,
      rgba(5, 3, 21, 0.75) 40%,
      rgba(5, 3, 21, 0.45) 100%
    );
  }

  /* ─── Content ─── */
  .hp-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    min-height: 70vh;
    padding-top: 4rem;
    padding-bottom: 3.5rem;
  }

  .hp-inner {
    width: 100%;
    max-width: 680px;
  }

  /* Eyebrow */
  .hp-eyebrow-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .hp-eyebrow-line {
    width: 2.5rem;
    height: 3px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .hp-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
  }

  /* Title */
  .hp-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.08;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }

  /* Trust indicators */
  .hp-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin-bottom: 2rem;
  }
  .hp-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hp-trust-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--brand-highlight);
    flex-shrink: 0;
  }

  /* ─── Buttons ─── */
  .hp-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.75rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hp-btn-highlight {
    background: var(--brand-highlight);
    color: var(--brand-primary);
  }
  .hp-btn-highlight:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }

  .hp-btn-outline {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .hp-btn-outline:hover {
    border-color: var(--brand-highlight);
    color: var(--brand-highlight);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hp-content {
      min-height: 55vh;
      padding-top: 3rem;
      padding-bottom: 2.5rem;
    }
    .hp-eyebrow {
      font-size: 0.6rem;
    }
  }

  @media (max-width: 480px) {
    .hp-actions {
      flex-direction: column;
    }
    .hp-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
