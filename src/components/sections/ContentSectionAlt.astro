---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface FeatureItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  featuresTitle?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  image?: string;
  imageAlt?: string;
}

const {
  badge,
  title: rawTitle,
  titleHighlight: rawTitleHighlight,
  description: rawDescription,
  featuresTitle,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  image,
  imageAlt = "Section image"
} = Astro.props;

const title = getLocationText(rawTitle);
const titleHighlight = rawTitleHighlight ? getLocationText(rawTitleHighlight) : undefined;
const description = getLocationText(rawDescription);
const features = rawFeatures.map(f => ({
  ...f,
  title: getLocationText(f.title),
  description: getLocationText(f.description),
}));

const isRight = imagePosition === "right";
---

<section class="csa-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-16">

    <!-- Banner strip -->
    <div class:list={["csa-banner", { "csa-banner--flipped": isRight }]} data-animate="fade-up">

      <!-- Dark text side -->
      <div class="csa-dark">
        <!-- Decorative arcs -->
        <div class="csa-arcs">
          <div class="csa-arc csa-arc--1"></div>
          <div class="csa-arc csa-arc--2"></div>
          <div class="csa-arc csa-arc--3"></div>
        </div>

        <div class="csa-dark-content">
          {badge && (
            <div class="csa-badge-wrap">
              <div class="csa-badge-line"></div>
              <span class="csa-badge">{badge}</span>
            </div>
          )}

          <h2 class="csa-title">
            {title}{" "}
            {titleHighlight && (
              <span class="csa-title-hl">{titleHighlight}</span>
            )}
          </h2>

          <p class="csa-desc" set:html={description} />

          {buttonHref && (
            <a href={buttonHref} class="csa-btn">
              {buttonText || "Read More"}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Image side -->
      <div class="csa-img-side">
        {image ? (
          <Image
            src={image}
            alt={imageAlt}
            class="csa-img"
            width={800}
            height={500}
            format="webp"
            quality={75}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="csa-img csa-img--placeholder">
            <span>Image</span>
          </div>
        )}
      </div>
    </div>

    <!-- Features below the banner (if any) -->
    {features.length > 0 && (
      <div class="csa-features" data-animate-stagger>
        {featuresTitle && (
          <h3 class="csa-features-heading">{featuresTitle}</h3>
        )}
        <div class="csa-features-grid">
          {features.map((feature, i) => (
            <div class="csa-feature">
              <div class="csa-feature-num">{String(i + 1).padStart(2, "0")}</div>
              <h4 class="csa-feature-title">{feature.title}</h4>
              <p class="csa-feature-desc" set:html={feature.description} />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .csa-section {
    background: var(--background);
  }

  /* ─── Banner Strip ─── */
  .csa-banner {
    display: grid;
    grid-template-columns: 40% 60%;
    overflow: hidden;
  }
  .csa-banner--flipped {
    grid-template-columns: 60% 40%;
    direction: rtl;
  }
  .csa-banner--flipped > * {
    direction: ltr;
  }

  /* ─── Dark Side ─── */
  .csa-dark {
    position: relative;
    background: var(--brand-primary);
    padding: 2.5rem 2.5rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Decorative arcs */
  .csa-arcs {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 140px;
    height: 140px;
    pointer-events: none;
  }
  .csa-arc {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .csa-arc--1 {
    width: 100%;
    height: 100%;
    inset: 0;
  }
  .csa-arc--2 {
    width: 70%;
    height: 70%;
    bottom: 0;
    right: 0;
  }
  .csa-arc--3 {
    width: 40%;
    height: 40%;
    bottom: 0;
    right: 0;
  }

  .csa-dark-content {
    position: relative;
    z-index: 2;
  }

  /* Badge */
  .csa-badge-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .csa-badge-line {
    width: 2rem;
    height: 3px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .csa-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand-highlight);
  }

  /* Title */
  .csa-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.75rem;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .csa-title-hl {
    color: var(--brand-highlight);
  }
  @media (min-width: 1024px) {
    .csa-title { font-size: 2rem; }
  }

  /* Description */
  .csa-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.5rem;
    max-width: 400px;
  }

  /* CTA */
  .csa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.7rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .csa-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }

  /* ─── Image Side ─── */
  .csa-img-side {
    position: relative;
    overflow: hidden;
  }

  .csa-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .csa-img--placeholder {
    background: var(--brand-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  /* ─── Features Grid (below banner) ─── */
  .csa-features {
    margin-top: 2.5rem;
  }

  .csa-features-heading {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
    margin-bottom: 1.5rem;
  }

  .csa-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .csa-feature {
    padding: 1.75rem;
    border: 1px solid color-mix(in srgb, var(--brand-primary) 8%, transparent);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .csa-feature:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .csa-feature-num {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    color: var(--brand-highlight);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .csa-feature-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--brand-primary);
    margin-bottom: 0.5rem;
  }

  .csa-feature-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--brand-secondary);
  }
  .csa-feature-desc :global(a) {
    color: var(--brand-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .csa-feature-desc :global(strong) {
    color: var(--brand-primary);
    font-weight: 700;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .csa-banner,
    .csa-banner--flipped {
      grid-template-columns: 1fr;
      direction: ltr;
    }
    .csa-dark {
      padding: 2rem 1.5rem;
    }
    .csa-img-side {
      max-height: 260px;
    }
    .csa-features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
