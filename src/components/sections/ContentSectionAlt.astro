---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface FeatureItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  featuresTitle?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  image?: string;
  imageAlt?: string;
}

const {
  badge,
  title: rawTitle,
  titleHighlight: rawTitleHighlight,
  description: rawDescription,
  featuresTitle,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  image,
  imageAlt = "Section image"
} = Astro.props;

const title = getLocationText(rawTitle);
const titleHighlight = rawTitleHighlight ? getLocationText(rawTitleHighlight) : undefined;
const description = getLocationText(rawDescription);
const features = rawFeatures.map(f => ({
  ...f,
  title: getLocationText(f.title),
  description: getLocationText(f.description),
}));

const isRight = imagePosition === "right";
---

<section class="csa-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-16">

    <!-- Centered header section -->
    <div class="csa-header" data-animate="fade-up">
      {badge && (
        <div class="csa-eyebrow mb-5">
          <svg class="csa-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          <span class="csa-eyebrow-text">{badge}</span>
        </div>
      )}

      <h2 class="csa-title">
        {title}{" "}
        {titleHighlight && (
          <span class="csa-title-hl">{titleHighlight}</span>
        )}
      </h2>

      <p class="csa-desc" set:html={description} />

      {buttonHref && (
        <a href={buttonHref} class="csa-btn">
          {buttonText || "Read More"}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </div>

    <!-- Features below the header (if any) -->
    {features.length > 0 && (
      <div class="csa-features" data-animate-stagger>
        {featuresTitle && (
          <h3 class="csa-features-heading">{featuresTitle}</h3>
        )}
        <div class="csa-features-grid">
          {features.map((feature, i) => (
            <div class="csa-feature">
              <div class="csa-feature-num">{String(i + 1).padStart(2, "0")}</div>
              <h4 class="csa-feature-title">{feature.title}</h4>
              <p class="csa-feature-desc" set:html={feature.description} />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .csa-section {
    background-image: url('https://images.unsplash.com/photo-1584531979583-18c5c4b25efc?q=60&w=400&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
    position: relative;
  }
  
  @media (min-width: 768px) {
    .csa-section {
      background-image: url('https://images.unsplash.com/photo-1584531979583-18c5c4b25efc?q=70&w=1200&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
      background-attachment: fixed;
    }
  }
  .csa-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.95);
    z-index: 0;
  }
  .csa-section > .container {
    position: relative;
    z-index: 1;
  }

  /* ─── Centered Header ─── */
  .csa-header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 3rem;
  }

  /* Badge */
  .csa-badge-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .csa-badge-line {
    width: 3rem;
    height: 4px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .csa-badge {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
  }

  /* Eyebrow */
  .csa-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .csa-fan-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .csa-eyebrow-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    background: none;
  }

  /* Title */
  .csa-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 45px;
    line-height: 1.15;
    color: var(--brand-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  .csa-title-hl {
    color: var(--brand-highlight);
    display: inline-block;
    position: relative;
  }

  /* Description */
  .csa-desc {
    font-size: 18px;
    line-height: 1.8;
    color: var(--brand-secondary);
    margin-bottom: 2rem;
    max-width: 750px;
    margin-left: auto;
    margin-right: auto;
  }

  /* CTA */
  .csa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 2rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 14px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(255, 165, 0, 0.3);
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }
  .csa-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }
  .csa-btn:hover::before {
    left: 100%;
  }
  .csa-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(255, 165, 0, 0.4);
  }

  /* ─── Features Grid (below banner) ─── */
  .csa-features {
    margin-top: 2.5rem;
  }

  .csa-features-heading {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
    margin-bottom: 1.5rem;
  }

  .csa-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .csa-feature {
    padding: 2rem 1.75rem;
    border: 2px solid color-mix(in srgb, var(--brand-primary) 8%, transparent);
    transition: all 0.3s ease;
    position: relative;
    background: white;
    overflow: hidden;
  }
  .csa-feature::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.3s ease;
  }
  .csa-feature:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }
  .csa-feature:hover::before {
    height: 100%;
  }

  .csa-feature-num {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.875rem;
    color: var(--brand-highlight);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: color-mix(in srgb, var(--brand-highlight) 10%, transparent);
    border-radius: 4px;
  }

  .csa-feature-title {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--brand-primary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .csa-feature-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--brand-secondary);
  }
  .csa-feature-desc :global(a) {
    color: var(--brand-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .csa-feature-desc :global(strong) {
    color: var(--brand-primary);
    font-weight: 700;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .csa-header {
      margin-bottom: 2rem;
    }
    .csa-title {
      font-size: 2rem;
    }
    .csa-desc {
      font-size: 1rem;
    }
    .csa-features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
