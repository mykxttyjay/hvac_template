---
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge = "Testimonials", title: rawTitle, description: rawDescription, testimonials: rawTestimonials } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const testimonials = rawTestimonials.map(t => ({ ...t, content: getLocationText(t.content) }));
---

<section class="tm-section">
  <div class="tm-body">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">

      <!-- Header -->
      <div class="tm-header" data-animate="fade-up">
        <div class="tm-eyebrow">
          <span class="tm-eyebrow-text">{badge}</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
          <h2 class="tm-title">{title}</h2>
          {description && <p class="tm-desc" set:html={description} />}
        </div>
      </div>

      <!-- Carousel -->
      <div class="tm-carousel" data-animate="fade-up" data-animate-delay="100">
        <div class="tm-viewport">
          <div class="tm-track">
            {testimonials.map((t) => (
              <div class="tm-slide">
                <div class="tm-card group">
                  {/* Left accent strip */}
                  <span class="tm-card-strip"></span>

                  <div class="tm-card-inner">
                    {/* Top row: quote + stars */}
                    <div class="tm-card-top">
                      <div class="tm-quote" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                      </div>
                      <div class="tm-stars" role="img" aria-label={`${t.rating} out of 5 stars`}>
                        {Array.from({ length: 5 }).map((_, i) => (
                          <svg xmlns="http://www.w3.org/2000/svg" class:list={["tm-star", { "tm-star--filled": i < t.rating }]} viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        ))}
                      </div>
                    </div>

                    <p class="tm-content" set:html={t.content} />

                    {/* Author */}
                    <div class="tm-author">
                      <div class="tm-avatar"><span>{t.initials}</span></div>
                      <div class="tm-author-info">
                        <span class="tm-name">{t.name}</span>
                        <span class="tm-date">{t.date}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Controls -->
        <div class="tm-controls">
          <button class="tm-arrow tm-arrow--prev" aria-label="Previous testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <div class="tm-dots"></div>
          <button class="tm-arrow tm-arrow--next" aria-label="Next testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tm-section {
    position: relative;
    background: var(--background);
  }

  .tm-body {
    background: #fff;
    padding: 4rem 0 5rem;
  }

  /* ─── Header ─── */
  .tm-header {
    margin-bottom: 2.5rem;
  }

  .tm-eyebrow {
    margin-bottom: 1.5rem;
  }
  .tm-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  .tm-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) {
    .tm-title { font-size: 2.5rem; }
  }

  .tm-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Carousel ─── */
  .tm-carousel {
    position: relative;
  }

  .tm-viewport {
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }
  .tm-viewport:active {
    cursor: grabbing;
  }

  .tm-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }
  .tm-track.is-dragging {
    transition: none;
  }

  .tm-slide {
    flex-shrink: 0;
    width: calc(100% / 3);
    padding: 0 0.625rem;
    box-sizing: border-box;
  }

  /* ─── Card ─── */
  .tm-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.18);
    overflow: hidden;
    transition: all 0.35s ease;
    height: 100%;
  }
  .tm-card:hover {
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  .tm-card-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
    z-index: 1;
  }
  .tm-card:hover .tm-card-strip {
    height: 100%;
  }

  .tm-card-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 320px;
  }

  .tm-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .tm-quote {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-tertiary);
    border: 1px solid rgba(0,0,0,0.06);
    color: var(--brand-primary);
    transition: all 0.3s ease;
  }
  .tm-card:hover .tm-quote {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    color: var(--brand-primary);
  }

  .tm-stars {
    display: flex;
    gap: 2px;
  }
  .tm-star { color: rgba(0,0,0,0.12); }
  .tm-star--filled { color: var(--brand-highlight); }

  .tm-content {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--brand-secondary);
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .tm-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .tm-avatar {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--brand-primary);
    color: var(--brand-highlight);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }
  .tm-card:hover .tm-avatar {
    background: var(--brand-highlight);
    color: var(--brand-primary);
  }
  .tm-author-info { display: flex; flex-direction: column; }
  .tm-name {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
  }
  .tm-date {
    font-size: 0.7rem;
    color: var(--brand-secondary);
    letter-spacing: 0.05em;
  }

  /* ─── Controls ─── */
  .tm-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .tm-arrow {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .tm-arrow:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    border-color: var(--brand-highlight);
  }

  .tm-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .tm-dots :global(button) {
    width: 24px;
    height: 3px;
    border: none;
    background: rgba(0,0,0,0.15);
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }
  .tm-dots :global(button.is-active) {
    background: var(--brand-highlight);
    width: 40px;
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .tm-slide {
      width: 50%;
    }
  }
  @media (max-width: 640px) {
    .tm-slide {
      width: 100%;
      padding: 0 0.375rem;
    }
  }
</style>

<script>
  function initTestimonialsCarousel() {
    document.querySelectorAll<HTMLElement>('.tm-carousel').forEach((carousel) => {
      const viewport = carousel.querySelector<HTMLElement>('.tm-viewport');
      const track = carousel.querySelector<HTMLElement>('.tm-track');
      const prevBtn = carousel.querySelector<HTMLElement>('.tm-arrow--prev');
      const nextBtn = carousel.querySelector<HTMLElement>('.tm-arrow--next');
      const dotsContainer = carousel.querySelector<HTMLElement>('.tm-dots');
      if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) return;
      if (track.dataset.init === 'true') return;
      track.dataset.init = 'true';

      const slides = track.querySelectorAll<HTMLElement>('.tm-slide');
      const totalSlides = slides.length;
      const controls = carousel.querySelector<HTMLElement>('.tm-controls');
      let currentIndex = 0;
      let perView = getPerView();

      function getPerView(): number {
        if (window.innerWidth <= 640) return 1;
        if (window.innerWidth <= 1024) return 2;
        return 3;
      }

      const maxIndex = () => Math.max(0, totalSlides - perView);

      function syncControlsVisibility() {
        if (!controls) return;
        controls.style.display = maxIndex() > 0 ? '' : 'none';
      }

      function buildDots() {
        dotsContainer!.innerHTML = '';
        const count = maxIndex() + 1;
        if (count <= 1) return;
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.setAttribute('aria-label', `Go to slide group ${i + 1}`);
          if (i === currentIndex) dot.classList.add('is-active');
          dot.addEventListener('click', () => goTo(i));
          dotsContainer!.appendChild(dot);
        }
      }

      function updateDots() {
        const dots = dotsContainer!.querySelectorAll('button');
        dots.forEach((d, i) => d.classList.toggle('is-active', i === currentIndex));
      }

      function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const slideWidth = slides[0].offsetWidth;
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        updateDots();
      }

      function next() { goTo(currentIndex >= maxIndex() ? 0 : currentIndex + 1); }
      function prev() { goTo(currentIndex <= 0 ? maxIndex() : currentIndex - 1); }

      prevBtn.addEventListener('click', prev);
      nextBtn.addEventListener('click', next);

      let startX = 0;
      let dragOffset = 0;
      let isDragging = false;
      let trackOffset = 0;

      viewport.addEventListener('mousedown', (e) => {
        isDragging = true; startX = e.clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        dragOffset = e.clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      });
      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      });

      viewport.addEventListener('touchstart', (e) => {
        isDragging = true; startX = e.touches[0].clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
      }, { passive: true });
      viewport.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        dragOffset = e.touches[0].clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { passive: true });
      viewport.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      }, { passive: true });

      window.addEventListener('resize', () => {
        perView = getPerView();
        buildDots();
        syncControlsVisibility();
        goTo(Math.min(currentIndex, maxIndex()));
      });

      buildDots();
      syncControlsVisibility();
      goTo(0);
    });
  }

  initTestimonialsCarousel();
  document.addEventListener('astro:page-load', initTestimonialsCarousel);
</script>
