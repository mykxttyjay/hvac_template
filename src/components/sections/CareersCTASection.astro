---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title: rawTitle,
  description: rawDescription,
  buttonText = "APPLY TODAY",
  buttonHref = "/contact",
  image,
  imageAlt = "Join our team"
} = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
---

<section class="cc-section">
  <!-- Geometric slope accent -->
  <div class="cc-slope">
    <svg class="h-full w-full" viewBox="0 0 200 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="60,0 200,0 200,800 0,800" fill="white" opacity="0.03" />
      <polygon points="100,0 200,0 200,800 40,800" fill="white" opacity="0.02" />
    </svg>
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28 relative z-10">
    <div class="cc-layout">

      <!-- Text side -->
      <div class="cc-text" data-animate="fade-right">
        <div class="cc-eyebrow">
          <span class="cc-eyebrow-text">Join Us</span>
        </div>

        <h2 class="cc-title">{title}</h2>
        <div class="cc-divider"></div>

        {description && (
          <p class="cc-desc" set:html={description} />
        )}

        <a href={buttonHref} class="cc-btn">
          {buttonText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Image side -->
      <div class="cc-image-side" data-animate="fade-left">
        {image ? (
          <div class="cc-image-wrap">
            <img
              src={image}
              alt={imageAlt}
              class="cc-image"
              loading="lazy"
            />
            <div class="cc-image-overlay"></div>

            <!-- Vertical highlight strip -->
            <div class="cc-image-strip"></div>
          </div>
        ) : (
          <div class="cc-image-wrap cc-image-placeholder">
            <span>Image</span>
          </div>
        )}
      </div>

    </div>
  </div>
</section>

<style>
  .cc-section {
    background: var(--brand-primary);
    position: relative;
    overflow: hidden;
  }

  .cc-slope {
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* ─── Layout ─── */
  .cc-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: center;
  }

  /* ─── Text Side ─── */
  .cc-eyebrow {
    margin-bottom: 1.25rem;
  }
  .cc-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--brand-highlight);
  }

  .cc-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .cc-title { font-size: 2.25rem; }
  }

  .cc-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin-bottom: 1.25rem;
  }

  .cc-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 2rem;
  }

  .cc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.8rem 2rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .cc-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .cc-btn svg {
    transition: transform 0.3s ease;
  }
  .cc-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Image Side ─── */
  .cc-image-wrap {
    position: relative;
    overflow: hidden;
  }
  .cc-image {
    width: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    transition: transform 0.6s ease;
  }
  .cc-image-wrap:hover .cc-image {
    transform: scale(1.04);
  }

  .cc-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--brand-primary) 25%, transparent) 0%,
      transparent 50%
    );
  }

  .cc-image-strip {
    position: absolute;
    top: 10%;
    left: 0;
    width: 3px;
    height: 40%;
    background: var(--brand-highlight);
    z-index: 2;
  }

  .cc-image-placeholder {
    aspect-ratio: 4 / 3;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.875rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .cc-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .cc-image-side {
      order: -1;
    }
    .cc-image {
      aspect-ratio: 16 / 9;
    }
  }
</style>
