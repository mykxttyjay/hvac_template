---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  benefits?: string[];
}

const { title: rawTitle, description: rawDescription, subtitle: rawSubtitle, benefits: rawBenefits = [] } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const benefits = rawBenefits.map(getLocationText);
---

<section class="fi-section" style="background-image: url('https://images.unsplash.com/photo-1615799998603-7c6270a45196?q=80&w=704&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'); background-size: cover; background-position: center; background-attachment: fixed;">
  <div class="absolute inset-0 bg-white/75"></div>
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-16 relative z-10">

    <!-- Header -->
    <div class="fi-header" data-animate="fade-up">
      <div class="fi-eyebrow">
        <svg class="fi-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        <span class="fi-eyebrow-text">Financing</span>
      </div>
      <h2 class="fi-title">{title}</h2>
      <div class="fi-divider"></div>
      <p class="fi-desc" set:html={description} />
    </div>

    <!-- Benefits cards -->
    {subtitle && benefits.length > 0 && (
      <div class="fi-benefits-section" data-animate="fade-up" data-animate-delay="200">
        <h3 class="fi-benefits-title">{subtitle}</h3>
        <div class="fi-benefits-grid">
          {benefits.map((benefit, index) => (
            <div class="fi-benefit-card">
              <div class="fi-benefit-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {index === 0 && <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>}
                  {index === 1 && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
                  {index === 2 && <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
                  {index === 3 && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></>}
                  {index > 3 && <><polyline points="20 6 9 17 4 12"/></>}
                </svg>
              </div>
              <h4 class="fi-benefit-title">{benefit}</h4>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .fi-section {
    background: var(--brand-tertiary);
    position: relative;
    overflow: hidden;
  }

  /* ─── Header ─── */
  .fi-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }
  .fi-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .fi-fan-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .fi-eyebrow-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    background: none;
  }
  .fi-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .fi-title { font-size: 45px; }
  }
  .fi-divider {
    display: none;
  }
  .fi-desc {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Benefits Section ─── */
  .fi-benefits-section {
    max-width: 80rem;
    margin: 0 auto;
  }

  .fi-benefits-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
    color: var(--brand-primary);
    margin-bottom: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .fi-benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    align-items: stretch;
  }

  .fi-benefit-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 1rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
    min-height: 90px;
  }
  .fi-benefit-card:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .fi-benefit-icon {
    width: 64px;
    height: 64px;
    background: rgba(244, 145, 29, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-highlight);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }
  .fi-benefit-card:hover .fi-benefit-icon {
    background: var(--brand-highlight);
    color: white;
    transform: scale(1.05);
  }

  .fi-benefit-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--brand-primary);
    line-height: 1.3;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .fi-benefits-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
