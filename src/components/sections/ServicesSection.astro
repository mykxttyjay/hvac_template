---
interface Service {
  title: string;
  description: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: Service[];
}

interface Props {
  title: string;
  description: string;
  categories: ServiceCategory[];
  badge?: string;
}

const { title, description, categories, badge = "Our Services" } = Astro.props;
---

<section class="ss-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Header -->
    <div class="ss-header" data-animate="fade-up">
      <div class="ss-eyebrow">
        <span class="ss-eyebrow-text">{badge}</span>
      </div>

      <div class="ss-header-grid">
        <h2 class="ss-title">{title}</h2>
        <p class="ss-desc" set:html={description} />
      </div>
    </div>

    <!-- Tabs Navigation -->
    <div class="ss-tabs-nav">
      {categories.map((category, index) => (
        <button
          class="ss-tab-btn"
          data-tab={index}
          data-active={index === 0 ? "true" : "false"}
        >
          {category.title}
        </button>
      ))}
    </div>

    <!-- Tab Content -->
    <div class="ss-tabs-content">
      {categories.map((category, index) => (
        <div
          class="ss-tab-panel"
          data-panel={index}
          data-active={index === 0 ? "true" : "false"}
        >
          <div class="ss-grid">
            {category.services.map((service) => {
              const isLink = !!service.href;
              const Tag = isLink ? 'a' : 'div';
              return (
                <Tag
                  {...(isLink ? { href: service.href } : {})}
                  class="ss-card group"
                >
                  <span class="ss-card-strip"></span>

                  <div class="ss-card-inner">
                    <h4 class="ss-card-title">{service.title}</h4>
                    <p class="ss-card-desc" set:html={service.description} />

                    {isLink && (
                      <div class="ss-arrow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </div>
                    )}
                  </div>
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initTabs() {
    const tabButtons = document.querySelectorAll('.ss-tab-btn');
    const tabPanels = document.querySelectorAll('.ss-tab-panel');

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tabIndex = button.getAttribute('data-tab');

        // Update buttons
        tabButtons.forEach((btn) => {
          btn.setAttribute('data-active', 'false');
        });
        button.setAttribute('data-active', 'true');

        // Update panels
        tabPanels.forEach((panel) => {
          panel.setAttribute('data-active', 'false');
        });
        const activePanel = document.querySelector(`[data-panel="${tabIndex}"]`);
        if (activePanel) {
          activePanel.setAttribute('data-active', 'true');
        }
      });
    });
  }

  // Initialize on page load
  initTabs();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTabs);
</script>

<style>
  .ss-section {
    background: var(--background);
  }

  /* ─── Header ─── */
  .ss-header {
    margin-bottom: 3rem;
  }
  .ss-eyebrow {
    margin-bottom: 1.5rem;
  }
  .ss-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  .ss-header-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .ss-header-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .ss-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    text-align: left;
  }
  @media (min-width: 768px) {
    .ss-title { font-size: 2.5rem; }
  }

  .ss-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
    text-align: left;
  }

  /* ─── Tabs Navigation ─── */
  .ss-tabs-nav {
    display: flex;
    justify-content: flex-start;
    gap: 0;
    margin-bottom: 3rem;
    border-bottom: 2px solid #e5e7eb;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ss-tab-btn {
    position: relative;
    padding: 1rem 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-secondary);
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    margin-bottom: -2px;
  }

  .ss-tab-btn:hover {
    color: var(--brand-primary);
    background: rgba(244, 145, 29, 0.05);
  }

  .ss-tab-btn[data-active="true"] {
    color: var(--brand-primary);
    background: transparent;
    border-bottom-color: var(--brand-highlight);
  }

  /* ─── Tab Panels ─── */
  .ss-tabs-content {
    position: relative;
  }

  .ss-tab-panel {
    display: none;
  }

  .ss-tab-panel[data-active="true"] {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Cards Grid ─── */
  .ss-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .ss-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ─── Card ─── */
  .ss-card {
    position: relative;
    display: block;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transition: all 0.35s ease;
    text-decoration: none;
    color: inherit;
  }
  .ss-card:hover {
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
  }

  .ss-card-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
  }
  .ss-card:hover .ss-card-strip {
    height: 100%;
  }

  .ss-card-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: 140px;
  }

  .ss-card-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--brand-primary);
    margin-bottom: 0.5rem;
    line-height: 1.25;
    transition: color 0.3s ease;
  }

  .ss-card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--brand-secondary);
    margin-bottom: auto;
    padding-bottom: 1rem;
  }

  .ss-arrow {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-tertiary);
    color: var(--brand-secondary);
    transition: all 0.3s ease;
  }
  .ss-card:hover .ss-arrow {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .ss-grid {
      grid-template-columns: 1fr;
    }
    
    .ss-tabs-nav {
      justify-content: flex-start;
      gap: 0;
    }
    
    .ss-tab-btn {
      padding: 0.875rem 1.25rem;
      font-size: 0.7rem;
    }
  }
</style>
