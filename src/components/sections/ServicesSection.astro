---
interface ServiceCard {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: ServiceCard[];
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { badge = "OUR SERVICES", title, description, categories } = Astro.props;
---

<section class="relative bg-gradient-to-b from-gray-50 to-white overflow-hidden pt-12 md:pt-16 pb-4 md:pb-6" style="background-image: url('https://images.unsplash.com/photo-1584531979583-18c5c4b25efc?q=60&w=400&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'); background-size: cover; background-position: center; background-attachment: scroll;">
  <style>
    @media (min-width: 768px) {
      section {
        background-image: url('https://images.unsplash.com/photo-1584531979583-18c5c4b25efc?q=70&w=1200&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D') !important;
        background-attachment: fixed;
      }
    }
  </style>
  <div class="absolute inset-0 bg-white/50"></div>
  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    <!-- Header -->
    <div class="mb-8 max-w-6xl mx-auto text-center" data-animate="fade-up">
      <div class="mb-6 flex items-center justify-center gap-3">
        <svg class="svc-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        <span class="font-bold uppercase tracking-[0.2em] text-brand-highlight" style="font-size: 14px;">{badge}</span>
      </div>

      <div class="grid grid-cols-1 gap-4 items-center text-center">
        <h2 class="text-4xl md:text-5xl lg:text-[45px] font-extrabold uppercase tracking-tight leading-[1.1] text-brand-primary max-w-4xl mx-auto">
          {title}
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-gray-600 max-w-6xl mx-auto" set:html={description} />
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 sm:gap-4 mb-12 justify-center svc-tabs" data-animate="fade-up" data-animate-delay="100">
      {categories.map((category, index) => (
        <button
          class="svc-tab group relative px-6 py-3 text-sm font-bold uppercase tracking-wider transition-all duration-300 overflow-hidden bg-white border-2 border-gray-300 rounded-lg hover:shadow-md hover:border-brand-primary"
          data-tab={index}
          data-active={index === 0 ? "true" : "false"}
        >
          <span class="absolute inset-0 w-full h-full bg-brand-primary scale-0 opacity-0 transition-all duration-300 group-data-[active=true]:scale-100 group-data-[active=true]:opacity-100"></span>
          <span class="relative z-10 text-gray-600 group-hover:text-brand-primary group-data-[active=true]:text-white transition-colors duration-300">
            {category.title}
          </span>
        </button>
      ))}
    </div>

    <!-- Service Cards Grid -->
    <div class="relative min-h-[800px] sm:min-h-[600px] lg:min-h-[400px]">
      {categories.map((category, catIndex) => (
        <div
          class={`service-content absolute inset-0 transition-all duration-500 transform ${catIndex === 0 ? 'active' : 'inactive'}`}
          data-content={catIndex}
        >
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate-stagger>
            {category.services.map((service, serviceIndex) => {
              const Tag = service.href ? 'a' : 'div';
              return (
                <Tag
                  {...(service.href ? { href: service.href } : {})}
                  class="group relative bg-white border-2 border-gray-200 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-3 hover:shadow-xl hover:border-brand-primary flex flex-col h-full"
                  style={`transition-delay: ${serviceIndex * 70}ms`}
                >
                  <div class="p-8 flex-1 flex flex-col">
                    <div class="flex items-start justify-start text-brand-primary mb-6">
                      <span class="[&>svg]:w-10 [&>svg]:h-10" set:html={service.icon} />
                    </div>

                    <h3 class="text-lg font-bold text-gray-900 mb-3 leading-snug group-hover:text-brand-primary transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-base leading-relaxed text-gray-500 mb-6 flex-1" set:html={service.description} />

                    {service.href && (
                      <div class="mt-auto flex items-center justify-between gap-3 pt-5">
                        <span class="text-sm font-bold uppercase tracking-widest text-brand-highlight transition-colors group-hover:text-brand-primary">Learn More</span>
                        <div class="w-10 h-10 rounded-full bg-brand-highlight flex items-center justify-center text-white transition-all duration-300 group-hover:bg-brand-primary group-hover:scale-110 group-hover:shadow-lg">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                          </svg>
                        </div>
                      </div>
                    )}
                  </div>
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .svc-fan-icon {
    width: 20px;
    height: 20px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Service content states */
  .service-content {
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
  }

  .service-content.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .service-content.inactive {
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .svc-tab {
      font-size: 0.75rem;
      padding: 0.5rem 1rem;
    }
  }
</style>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLElement>('.svc-tab');
    const contents = document.querySelectorAll<HTMLElement>('.service-content');

    if (tabs.length === 0 || contents.length === 0) return;

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const tabIndex = tab.getAttribute('data-tab');

        // Batch DOM updates to avoid reflows
        tabs.forEach((t) => t.setAttribute('data-active', 'false'));
        tab.setAttribute('data-active', 'true');

        // Use CSS classes instead of inline styles to avoid reflows
        contents.forEach((content) => {
          const contentIndex = content.getAttribute('data-content');
          if (contentIndex === tabIndex) {
            content.classList.add('active');
            content.classList.remove('inactive');
          } else {
            content.classList.remove('active');
            content.classList.add('inactive');
          }
        });
      });
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabs);
  } else {
    initTabs();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTabs);
</script>
