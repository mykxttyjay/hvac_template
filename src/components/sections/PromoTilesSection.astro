---
import { Image } from "astro:assets";
import { siteConfig, getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;
const tiles = rawTiles.map(tile => ({
  ...tile,
  phone: tile.phone || siteConfig.contact.phoneFormatted,
  title: tile.title ? getLocationText(tile.title) : tile.title,
}));
---

<section class="pt-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">
    <div class="pt-grid" data-animate-stagger>

      {tiles.map((tile, index) => (
        <div class:list={["pt-card group", { "pt-card--featured": index === 1 }]}>

          {/* Background image */}
          {tile.bgImage && (
            <div class="pt-card-bg">
              <Image
                src={tile.bgImage}
                alt=""
                aria-hidden="true"
                class="pt-card-bg-img"
                width={600}
                height={460}
                format="webp"
                quality={55}
                loading="lazy"
                decoding="async"
              />
              <div class="pt-card-bg-overlay" />
            </div>
          )}

          {/* Top accent bar */}
          <span class="pt-card-accent"></span>

          {/* Content wrapper */}
          <div class="pt-card-inner">

            {/* Eyebrow tag */}
            <div class="pt-eyebrow">
              <span class="pt-eyebrow-text">
                {tile.tag || (tile.type === "maintenance" && "Plan") || (tile.type === "financing" && "Financing") || (tile.type === "emergency" && "Special")}
              </span>
            </div>

            {/* Icon */}
            <div class="pt-icon">
              {tile.type === "maintenance" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                </svg>
              )}
              {tile.type === "financing" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                </svg>
              )}
              {tile.type === "emergency" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              )}
            </div>

            {/* Main content */}
            <div class="pt-content">

              {tile.type === "maintenance" && (
                <div>
                  {tile.title && (
                    <h3 class="pt-title">{tile.title}</h3>
                  )}
                  {tile.priceLabel && (
                    <div class="pt-price-block">
                      <span class="pt-price-label">{tile.priceLabel[0]}</span>
                      <span class="pt-price-value">{tile.priceLabel[1]}</span>
                      <span class="pt-price-label">{tile.priceLabel[2]}</span>
                    </div>
                  )}
                  <p class="pt-note">Priority scheduling included</p>
                </div>
              )}

              {tile.type === "financing" && (
                <div>
                  {tile.headline && (
                    <div class="pt-headline-group">
                      {tile.headline.map((line) => (
                        <p class="pt-headline">{line}</p>
                      ))}
                    </div>
                  )}
                  {tile.subtext && (
                    <p class="pt-subtext">{tile.subtext}</p>
                  )}
                  <div class="pt-features">
                    <div class="pt-feature">
                      <span class="pt-feature-dot"></span>
                      <span>Quick approval process</span>
                    </div>
                    <div class="pt-feature">
                      <span class="pt-feature-dot"></span>
                      <span>Flexible payment options</span>
                    </div>
                  </div>
                </div>
              )}

              {tile.type === "emergency" && (
                <div>
                  {tile.discount && (
                    <p class="pt-discount">{tile.discount}</p>
                  )}
                  {tile.subheadline && (
                    <div class="pt-subheadline-group">
                      {tile.subheadline.map((line) => (
                        <p class="pt-subheadline">{line}</p>
                      ))}
                    </div>
                  )}
                  <div class="pt-checklist">
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>System inspection</span>
                    </div>
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>Filter replacement</span>
                    </div>
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>Performance report</span>
                    </div>
                  </div>
                  <p class="pt-note">Limited time offer</p>
                </div>
              )}
            </div>

            {/* CTA */}
            <div class="pt-cta">
              <a
                href={tile.buttonHref || "/contact"}
                class="pt-btn"
                aria-label={`${tile.buttonText} - ${tile.title || tile.headline?.join(' ') || tile.discount || 'promo'}`}
              >
                {tile.buttonText}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a
                href={`tel:${tile.phone.replace(/[^0-9]/g, '')}`}
                class="pt-phone"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                {tile.phone}
              </a>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  .pt-section {
    background: var(--brand-primary);
    position: relative;
  }

  /* ─── Grid ─── */
  .pt-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 76rem;
    margin: 0 auto;
    align-items: end;
  }

  @media (min-width: 768px) {
    .pt-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .pt-grid > :nth-child(2) {
      transform: translateY(-1.5rem);
    }
    .pt-grid > :nth-child(2):hover {
      transform: translateY(calc(-1.5rem - 4px));
    }
  }

  /* ─── Card ─── */
  .pt-card {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    transition: all 0.35s ease;
  }
  .pt-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
  }

  /* Featured card */
  .pt-card--featured {
    border-color: var(--brand-highlight);
    box-shadow: 0 0 0 1px var(--brand-highlight);
  }
  .pt-card--featured:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3), 0 0 30px color-mix(in srgb, var(--brand-highlight) 15%, transparent);
  }

  /* ─── Background Image ─── */
  .pt-card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pt-card-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .pt-card:hover .pt-card-bg-img {
    transform: scale(1.06);
  }
  .pt-card-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--brand-primary) 92%, transparent) 0%,
      color-mix(in srgb, var(--brand-primary) 85%, transparent) 100%
    );
  }

  /* ─── Top Accent Bar ─── */
  .pt-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--brand-highlight);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
    z-index: 2;
  }
  .pt-card:hover .pt-card-accent {
    transform: scaleX(1);
  }
  .pt-card--featured .pt-card-accent {
    transform: scaleX(1);
  }

  /* ─── Card Inner ─── */
  .pt-card-inner {
    position: relative;
    z-index: 1;
    padding: 2rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    min-height: 420px;
  }

  @media (min-width: 768px) {
    .pt-card-inner {
      padding: 2.25rem 1.75rem 2rem;
      min-height: 460px;
    }
  }

  /* ─── Eyebrow ─── */
  .pt-eyebrow {
    margin-bottom: 1.5rem;
  }
  .pt-eyebrow-text {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--brand-highlight);
  }

  /* ─── Icon ─── */
  .pt-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--brand-highlight);
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }
  .pt-card:hover .pt-icon {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    color: var(--brand-primary);
  }

  /* ─── Content ─── */
  .pt-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .pt-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
    color: #fff;
    margin-bottom: 1.25rem;
  }

  /* ─── Price Block (maintenance) ─── */
  .pt-price-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 1rem;
  }
  .pt-price-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
  }
  .pt-price-value {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1;
    color: var(--brand-highlight);
  }

  /* ─── Headline (financing) ─── */
  .pt-headline-group {
    margin-bottom: 0.75rem;
  }
  .pt-headline {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    color: #fff;
  }
  .pt-subtext {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.25rem;
  }

  /* ─── Features list ─── */
  .pt-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .pt-feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
  }
  .pt-feature-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }

  /* ─── Discount (emergency) ─── */
  .pt-discount {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .pt-subheadline-group {
    margin-bottom: 1.25rem;
  }
  .pt-subheadline {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ─── Checklist (emergency) ─── */
  .pt-checklist {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 0.75rem;
  }
  .pt-check-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ─── Note ─── */
  .pt-note {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 0.5rem;
  }

  /* ─── CTA ─── */
  .pt-cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .pt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.75rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    font-weight: 700;
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    align-self: flex-start;
  }
  .pt-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .pt-btn svg {
    transition: transform 0.3s ease;
  }
  .pt-btn:hover svg {
    transform: translateX(4px);
  }

  .pt-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color 0.3s ease;
    letter-spacing: 0.02em;
  }
  .pt-phone:hover {
    color: var(--brand-highlight);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .pt-card-inner {
      min-height: auto;
    }
  }
</style>
