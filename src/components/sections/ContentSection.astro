---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  pretitle?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
  imageHeight?: string;
}

const {
  badge,
  pretitle: rawPretitle,
  title: rawTitle,
  description: rawDescription,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = [],
  imageHeight = "420px",
} = Astro.props;

const pretitle = rawPretitle ? getLocationText(rawPretitle) : undefined;
const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const features = rawFeatures.map(getLocationText);

const mainImage = images[0] || "";
const isRight = imagePosition === "right";
---

<section class="cs-wrapper">
  {/* Background image on right side */}
  <div class="absolute top-0 right-0 w-1/3 h-full opacity-20 pointer-events-none" style="background-image: url('https://images.unsplash.com/photo-1691351582808-329cde17ffa2?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'); background-size: cover; background-position: center;"></div>
  
  <div class="cs-container">
    <div class:list={["cs-section relative z-10", { "cs-section--flipped": isRight }]}>
  <!-- Full-bleed image side -->
  <div class="cs-image-side">
    <div class="cs-image-wrapper">
      {mainImage ? (
        mainImage.startsWith('http') ? (
          <img
            src={mainImage}
            alt={imageAlts[0] || title}
            class="cs-image"
            loading="lazy"
            width="960"
            height="720"
            decoding="async"
            style={`max-height: ${imageHeight};`}
          />
        ) : (
          <Image
            src={mainImage}
            alt={imageAlts[0] || title}
            class="cs-image"
            loading="lazy"
            width={960}
            height={720}
            format="webp"
            quality={75}
            decoding="async"
            style={`max-height: ${imageHeight};`}
          />
        )
      ) : (
        <div class="cs-image cs-image--placeholder">
          <span>Image</span>
        </div>
      )}

      <!-- Simple vertical accent line -->
      <div class="cs-accent-line"></div>
    </div>
  </div>

  <!-- Text side -->
  <div class="cs-text-side">
    <div class="cs-text-inner">
      {badge && (
        <div class="cs-eyebrow">
          <svg class="cs-fan-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          <span class="cs-eyebrow-text">{badge}</span>
        </div>
      )}

      <div class="cs-header-group">
        <h2 class="cs-title">{title}</h2>

        <p class="cs-desc" set:html={description} />
      </div>

      {features.length > 0 && (
        <div class="cs-features">
          {features.map((feature, index) => {
            // Define icons for each feature
            const icons = [
              // Fast and Reliable Service - clock/speed icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/></svg>',
              // Certified Technicians - certificate/badge icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>',
              // Affordable Pricing - dollar/price icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>',
              // 24/7 Emergency Support - phone/support icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>'
            ];
            return (
              <div class="cs-feature">
                <span class="cs-feature-icon" set:html={icons[index] || icons[0]} />
                <span class="cs-feature-text" set:html={feature} />
              </div>
            );
          })}
        </div>
      )}

      {buttonText && buttonHref && (
        <a href={buttonHref} class="cs-btn">
          {buttonText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </div>
  </div>
</section>

<style>
  .cs-wrapper {
    background: var(--background);
    overflow: hidden;
    position: relative;
  }

  .cs-container {
    container: mx-auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .cs-container {
      padding: 0 3rem;
    }
  }

  @media (min-width: 1024px) {
    .cs-container {
      padding: 0 4rem;
    }
  }

  /* ─── Layout ─── */
  .cs-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: auto;
    overflow: hidden;
    max-width: 100%;
    gap: 0;
  }

  .cs-section--flipped {
    direction: rtl;
  }
  .cs-section--flipped > * {
    direction: ltr;
  }

  /* ─── Image side: with padding ─── */
  .cs-image-side {
    position: relative;
    overflow: visible;
    padding: 2.5rem 0 2.5rem 0;
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
  }

  @media (min-width: 768px) {
    .cs-image-side {
      padding: 2.5rem 0 2.5rem 0;
    }
  }

  @media (min-width: 1024px) {
    .cs-image-side {
      padding: 3.5rem 0 3.5rem 0;
    }
  }

  .cs-image-wrapper {
    position: relative;
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
    width: 100%;
  }

  .cs-vertical-text {
    display: none;
  }

  .cs-image {
    width: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    border-radius: 12px;
    max-width: 78%;
    margin-left: 1.5rem;
    height: auto;
  }

  @media (min-width: 768px) {
    .cs-image {
      max-width: 78%;
      margin-left: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .cs-image {
      max-width: 78%;
      margin-left: 4rem;
    }
  }

  .cs-image--placeholder {
    background: var(--brand-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  /* Simple vertical accent line on right edge */
  .cs-accent-line {
    position: absolute;
    top: 20%;
    right: 0;
    width: 4px;
    height: 60%;
    background: var(--brand-highlight);
    z-index: 2;
    display: none;
  }

  .cs-section--flipped .cs-accent-line {
    right: auto;
    left: 0;
  }

  /* ─── Text side ─── */
  .cs-text-side {
    display: flex;
    align-items: flex-start;
    padding: 2.5rem 2rem 2.5rem 2.5rem;
  }

  @media (min-width: 1024px) {
    .cs-text-side {
      padding: 3.5rem 4rem 3.5rem 3.5rem;
    }
  }

  .cs-text-inner {
    max-width: 560px;
  }

  /* Eyebrow */
  .cs-eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .cs-fan-icon {
    width: 20px;
    height: 20px;
    color: var(--brand-highlight);
    animation: spin 3s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .cs-eyebrow-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0;
    background: none;
  }

  /* Header group - left aligned */
  .cs-header-group {
    text-align: left;
    margin-bottom: 1rem;
  }

  /* Title */
  .cs-title {
    font-size: 45px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--brand-primary);
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .cs-title { font-size: 45px; }
  }
  @media (min-width: 1280px) {
    .cs-title { font-size: 45px; }
  }

  /* Description - below title */
  .cs-desc {
    font-size: 18px;
    line-height: 1.8;
    color: var(--brand-secondary);
    margin: 0 0 0.75rem 0;
  }

  /* ─── Features: centered grid layout ─── */
  .cs-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 2rem;
    margin-top: 0;
    padding-left: 0;
    position: relative;
  }

  .cs-features::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
    background: var(--brand-secondary);
    transform: translateX(-50%);
    opacity: 0.2;
  }

  .cs-features::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--brand-secondary);
    transform: translateY(-50%);
    opacity: 0.2;
  }

  .cs-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    border: none;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    position: relative;
    overflow: visible;
    text-align: center;
  }

  .cs-feature::before {
    content: none;
  }

  .cs-feature-icon {
    width: 48px;
    height: 48px;
    color: var(--brand-highlight);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border-radius: 0;
  }

  .cs-feature:hover .cs-feature-icon {
    background: transparent;
    transform: none;
  }

  .cs-feature-icon svg {
    width: 100%;
    height: 100%;
  }

  .cs-feature-text {
    font-size: 16px;
    font-weight: 700;
    color: var(--brand-primary);
    line-height: 1.4;
  }

  .cs-feature:hover {
    background: transparent;
    box-shadow: none;
    transform: none;
  }

  .cs-feature:hover::before {
    opacity: 0;
  }

  /* ─── CTA ─── */
  .cs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.7rem 1.75rem;
    background: var(--brand-highlight);
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    border-radius: 8px;
  }
  .cs-btn:hover {
    background: var(--brand-primary);
    color: #fff;
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .cs-section {
      grid-template-columns: 1fr;
    }
    .cs-section--flipped {
      direction: ltr;
      grid-template-columns: 1fr;
    }
    .cs-image-side {
      min-height: 350px;
    }
    .cs-accent-line {
      display: none;
    }
    .cs-text-side {
      padding: 3rem 1.5rem;
    }
    .cs-pretitle::before {
      flex: 0 0 40px;
    }
    .cs-features {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .cs-feature {
      padding: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .cs-features {
      grid-template-columns: 1fr;
    }
  }
</style>
