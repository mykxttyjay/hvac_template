---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  pretitle?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const {
  badge,
  pretitle: rawPretitle,
  title: rawTitle,
  description: rawDescription,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = [],
} = Astro.props;

const pretitle = rawPretitle ? getLocationText(rawPretitle) : undefined;
const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const features = rawFeatures.map(getLocationText);

const mainImage = images[0] || "";
const isRight = imagePosition === "right";
---

<section class="cs-wrapper">
  <div class:list={["cs-section", { "cs-section--flipped": isRight }]}>
  <!-- Full-bleed image side -->
  <div class="cs-image-side">
    {mainImage ? (
      mainImage.startsWith('http') ? (
        <img
          src={mainImage}
          alt={imageAlts[0] || title}
          class="cs-image"
          loading="lazy"
          width="960"
          height="720"
          decoding="async"
        />
      ) : (
        <Image
          src={mainImage}
          alt={imageAlts[0] || title}
          class="cs-image"
          loading="lazy"
          width={960}
          height={720}
          format="webp"
          quality={75}
          decoding="async"
        />
      )
    ) : (
      <div class="cs-image cs-image--placeholder">
        <span>Image</span>
      </div>
    )}

    <!-- Simple vertical accent line -->
    <div class="cs-accent-line"></div>
  </div>

  <!-- Text side -->
  <div class="cs-text-side">
    <div class="cs-text-inner">
      {badge && (
        <div class="cs-eyebrow">
          <span class="cs-eyebrow-text">{badge}</span>
        </div>
      )}

      <div class="cs-header-group">
        {pretitle && (
          <div class="cs-pretitle">{pretitle}</div>
        )}

        <h2 class="cs-title">{title}</h2>

        <p class="cs-desc" set:html={description} />
      </div>

      {features.length > 0 && (
        <div class="cs-features">
          {features.map((feature, index) => {
            // Define icons for each feature
            const icons = [
              // Fast and Reliable Service - clock/speed icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/></svg>',
              // Certified Technicians - certificate/badge icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>',
              // Affordable Pricing - dollar/price icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>',
              // 24/7 Emergency Support - phone/support icon
              '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>'
            ];
            return (
              <div class="cs-feature">
                <span class="cs-feature-icon" set:html={icons[index] || icons[0]} />
                <span class="cs-feature-text" set:html={feature} />
              </div>
            );
          })}
        </div>
      )}

      {buttonText && buttonHref && (
        <a href={buttonHref} class="cs-btn">
          {buttonText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </div>
  </div>
</section>

<style>
  .cs-wrapper {
    background: var(--background);
    overflow: hidden;
  }

  /* ─── Layout ─── */
  .cs-section {
    display: grid;
    grid-template-columns: 50% 50%;
    min-height: auto;
    overflow: hidden;
    max-width: 100%;
  }

  .cs-section--flipped {
    direction: rtl;
  }
  .cs-section--flipped > * {
    direction: ltr;
  }

  /* ─── Image side: full bleed ─── */
  .cs-image-side {
    position: relative;
    overflow: hidden;
  }

  .cs-image {
    width: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    min-height: 100%;
  }

  .cs-image--placeholder {
    background: var(--brand-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  /* Simple vertical accent line on right edge */
  .cs-accent-line {
    position: absolute;
    top: 20%;
    right: 0;
    width: 4px;
    height: 60%;
    background: var(--brand-highlight);
    z-index: 2;
  }

  .cs-section--flipped .cs-accent-line {
    right: auto;
    left: 0;
  }

  /* ─── Text side ─── */
  .cs-text-side {
    display: flex;
    align-items: center;
    padding: 2.5rem 2rem 2.5rem 2.5rem;
  }

  @media (min-width: 1024px) {
    .cs-text-side {
      padding: 3.5rem 4rem 3.5rem 3.5rem;
    }
  }

  .cs-text-inner {
    max-width: 560px;
  }

  /* Eyebrow */
  .cs-eyebrow {
    margin-bottom: 1.25rem;
  }
  .cs-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  /* Header group - left aligned */
  .cs-header-group {
    text-align: left;
    margin-bottom: 3rem;
  }

  /* Pretitle */
  .cs-pretitle {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-highlight);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
  }

  .cs-pretitle::before {
    content: '';
    flex: 0 0 60px;
    height: 3px;
    background: var(--brand-highlight);
  }

  .cs-pretitle::after {
    content: none;
  }

  /* Title */
  .cs-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--brand-primary);
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .cs-title { font-size: 2.5rem; }
  }
  @media (min-width: 1280px) {
    .cs-title { font-size: 45px; }
  }

  /* Description - below title */
  .cs-desc {
    font-size: 15px;
    line-height: 1.8;
    color: var(--brand-secondary);
    margin: 0;
  }

  /* ─── Features: vertical list ─── */
  .cs-features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-left: 0;
  }

  .cs-feature {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--brand-highlight);
    background: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .cs-feature:hover {
    background: var(--brand-tertiary);
    box-shadow: 0 4px 12px rgba(244, 145, 29, 0.15);
  }

  .cs-feature-icon {
    width: 24px;
    height: 24px;
    color: var(--brand-highlight);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-feature-icon svg {
    width: 100%;
    height: 100%;
  }

  .cs-feature-text {
    font-size: 15px;
    font-weight: 600;
    color: var(--brand-primary);
  }

  /* ─── CTA ─── */
  .cs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.7rem 1.75rem;
    background: var(--brand-highlight);
    color: #0a0a0a;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cs-btn:hover {
    filter: brightness(1.08);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .cs-section {
      grid-template-columns: 1fr;
    }
    .cs-section--flipped {
      direction: ltr;
      grid-template-columns: 1fr;
    }
    .cs-image-side {
      min-height: 350px;
    }
    .cs-accent-line {
      display: none;
    }
    .cs-text-side {
      padding: 3rem 1.5rem;
    }
    .cs-pretitle::before {
      flex: 0 0 40px;
    }
    .cs-features {
      grid-template-columns: 1fr;
    }
  }
</style>
