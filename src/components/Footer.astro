---
import { siteConfig } from "@/config/site"

const currentYear = new Date().getFullYear()

const airConditioningServices = [
  { title: "AC Repair", href: "/air-conditioning/ac-repair" },
  { title: "AC Tune-Up/ Maintenance", href: "/air-conditioning/ac-tune-up-maintenance" },
  { title: "AC Installation and Replacement", href: "/air-conditioning/ac-installation-replacement" },
  { title: "Mini-Split Systems", href: "/air-conditioning/mini-split-systems" },
  { title: "HVAC Brands", href: "/air-conditioning/hvac-brands" },
  { title: "HVAC Warranties", href: "/air-conditioning/hvac-warranties" },
  { title: "Thermostats", href: "/air-conditioning/thermostats" },
]

const heatingServices = [
  { title: "Furnace Repair", href: "/heating/furnace-repair" },
  { title: "Furnace Tune Up/ Maintenance", href: "/heating/furnace-tune-up-maintenance" },
  { title: "Furnace Installation and Replacement", href: "/heating/furnace-installation-replacement" },
  { title: "Boilers Installation and Replacement", href: "/heating/boilers-installation-replacement" },
]

const indoorAirQualityServices = [
  { title: "Air Filtration Systems", href: "/indoor-air-quality/air-filtration-systems" },
  { title: "Duct Cleaning and Sealing", href: "/indoor-air-quality/duct-cleaning-sealing" },
  { title: "Duct Repair and Replacement", href: "/indoor-air-quality/duct-repair-replacement" },
  { title: "Attic Insulation and Ventilation", href: "/indoor-air-quality/attic-insulation-ventilation" },
]

const emergencyServices = [
  { title: "24/7 AC Repairs", href: "/emergency/24-7-ac-repairs" },
  { title: "24/7 Heating and Cooling Repairs", href: "/emergency/24-7-heating-cooling-repairs" },
  { title: "24/7 Emergency Repairs", href: "/emergency/24-7-emergency-repairs" },
]

const companyLinks = [
  { title: "Home", href: "/" },
  { title: "About Us", href: "/about" },
  { title: "Reviews", href: "/reviews" },
  { title: "Contact Us", href: "/contact" },
   { title: "Careers", href: "/careers" },
  { title: "Service Areas", href: "/service-areas" },
]

const legalLinks = [
  { title: "Privacy Policy", href: "/privacy-policy" },
  { title: "Terms of Service", href: "/terms" },
  { title: "Sitemap", href: "/sitemap.xml" },
]
---

<footer class="ft-footer">
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <!-- ─── Main sitemap grid ─── -->
    <div class="ft-sitemap">
      <!-- Logo & Tagline Column -->
      <div class="ft-brand-col">
        <a href="/" class="ft-logo-link">
          <img
            src={siteConfig.logo.src}
            alt={siteConfig.logo.alt}
            class="ft-logo-img"
            width="48"
            height="48"
            loading="lazy"
            decoding="async"
          />
          <span class="ft-logo-text">{siteConfig.business.name}</span>
        </a>
        <p class="ft-tagline">Trusted HVAC experts serving {siteConfig.location.city} and surrounding areas.</p>
        
        <!-- CTA Button -->
        <div class="ft-cta-buttons">
          <a href="/contact" class="ft-schedule-btn">Schedule Service</a>
        </div>

        <!-- Contact Info -->
        <div class="ft-contact-info">
          <a href={`tel:${siteConfig.contact.phone}`} class="ft-contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" class="ft-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {siteConfig.contact.phoneFormatted}
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} class="ft-contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" class="ft-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            {siteConfig.contact.email}
          </a>
          <div class="ft-contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" class="ft-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{siteConfig.location.fullAddress}</span>
          </div>
        </div>
      </div>

      <!-- Air Conditioning Services Column -->
      <div class="ft-nav-col">
        <h3 class="ft-heading">Air Conditioning Services</h3>
        <ul class="ft-link-list">
          {airConditioningServices.map((link) => (
            <li><a href={link.href} class="ft-link">{link.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Heating Services Column -->
      <div class="ft-nav-col">
        <h3 class="ft-heading">Heating Services</h3>
        <ul class="ft-link-list">
          {heatingServices.map((link) => (
            <li><a href={link.href} class="ft-link">{link.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Indoor Air Quality Column -->
      <div class="ft-nav-col">
        <h3 class="ft-heading">Indoor Air Quality</h3>
        <ul class="ft-link-list">
          {indoorAirQualityServices.map((link) => (
            <li><a href={link.href} class="ft-link">{link.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Emergency Services Column -->
      <div class="ft-nav-col">
        <h3 class="ft-heading">Emergency Services</h3>
        <ul class="ft-link-list">
          {emergencyServices.map((link) => (
            <li><a href={link.href} class="ft-link">{link.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company Column -->
      <div class="ft-nav-col">
        <h3 class="ft-heading">Quick Links</h3>
        <ul class="ft-link-list">
          {companyLinks.map((link) => (
            <li><a href={link.href} class="ft-link">{link.title}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ─── Copyright bar ─── -->
    <div class="ft-copyright-bar">
      <p class="ft-copyright">
        &copy; {currentYear} {siteConfig.business.name}. All rights reserved.
      </p>
      <div class="ft-legal-links">
        {legalLinks.map((link) => (
          <a href={link.href} class="ft-legal-link">{link.title}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .ft-footer {
    background: var(--brand-primary);
    color: #fff;
    padding: 4rem 0 0;
  }

  /* ─── Main sitemap grid ─── */
  .ft-sitemap {
    display: grid;
    grid-template-columns: 1.8fr 1.3fr 1fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* ─── Brand column (logo + tagline + contact + quick links) ─── */
  .ft-brand-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ft-logo-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    margin-bottom: 0.25rem;
  }

  .ft-logo-img {
    height: 48px;
    width: 48px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .ft-logo-text {
    font-size: 1.125rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    line-height: 1.2;
  }

  .ft-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    max-width: 280px;
  }

  /* ─── CTA Buttons ─── */
  .ft-cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
    max-width: 280px;
  }

  .ft-phone-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: all 0.3s ease;
  }

  .ft-phone-btn:hover {
    border-color: var(--brand-highlight);
    color: var(--brand-highlight);
  }

  .ft-schedule-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1.5rem;
    background: var(--brand-highlight);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.3s ease;
    width: 100%;
    border-radius: 8px;
  }

  .ft-schedule-btn:hover {
    background: #fff;
    color: var(--brand-primary);
  }

  .ft-contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .ft-contact-link {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ft-contact-link:hover {
    color: var(--brand-highlight);
  }

  .ft-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    stroke: var(--brand-highlight);
  }

  /* ─── Navigation columns ─── */
  .ft-nav-col {
    display: flex;
    flex-direction: column;
  }

  .ft-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fff;
    margin: 0 0 1.5rem 0;
    padding-bottom: 0.625rem;
    border-bottom: 2px solid var(--brand-highlight);
  }

  .ft-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ft-link {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    position: relative;
  }

  .ft-link::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--brand-highlight);
    transition: width 0.3s ease;
  }

  .ft-link:hover {
    color: var(--brand-highlight);
    transform: translateX(4px);
  }

  .ft-link:hover::before {
    width: 100%;
  }

  /* ─── Copyright bar ─── */
  .ft-copyright-bar {
    padding: 1.75rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .ft-copyright {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .ft-legal-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .ft-legal-link {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }

  .ft-legal-link:hover {
    color: var(--brand-highlight);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1280px) {
    .ft-sitemap {
      grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
      gap: 2rem;
    }

    .ft-nav-col:last-child {
      grid-column: 2;
    }
  }

  @media (max-width: 1024px) {
    .ft-sitemap {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2.5rem;
    }

    .ft-brand-col {
      grid-column: 1 / -1;
      max-width: 500px;
    }

    .ft-nav-col:last-child {
      grid-column: auto;
    }
  }

  @media (max-width: 768px) {
    .ft-footer {
      padding: 3rem 0 0;
    }

    .ft-sitemap {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .ft-brand-col {
      grid-column: 1 / -1;
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .ft-sitemap {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .ft-copyright-bar {
      padding: 1.5rem 0;
      flex-direction: column;
      text-align: center;
    }

    .ft-legal-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
