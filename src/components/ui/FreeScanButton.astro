---
// Floating offer button that triggers the popup modal
// Only visible on desktop (md and up)
---

<div id="free-scan-wrapper" class="hidden md:block fixed bottom-8 right-8 z-40">
  <button
    id="free-scan-trigger"
    class="fab-btn group"
    aria-label="$69 service request special"
  >
    <!-- Icon -->
    <span class="fab-icon">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
          d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
      </svg>
    </span>

    <!-- Text -->
    <span class="fab-text">
      <span class="fab-label">Service Special</span>
      <span class="fab-value">$69 Offer</span>
    </span>

    <!-- Highlight strip -->
    <span class="fab-strip"></span>
  </button>
</div>

<style>
  #free-scan-wrapper {
    animation: fab-enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.5s both;
  }

  .fab-btn {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.75rem 1rem 1rem;
    background: var(--brand-primary);
    color: #fff;
    border: 2px solid var(--brand-highlight);
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(244, 145, 29, 0.4), 0 4px 16px rgba(0,0,0,0.3);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
    border-radius: 4px;
  }
  
  .fab-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: left 0.6s;
  }
  
  .fab-btn:hover::before {
    left: 100%;
  }
  
  .fab-btn:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 48px rgba(244, 145, 29, 0.6), 0 8px 24px rgba(0,0,0,0.4);
    border-color: var(--brand-highlight);
    background: color-mix(in srgb, var(--brand-primary) 95%, var(--brand-highlight) 5%);
  }
  
  .fab-btn:active {
    transform: translateY(-2px) scale(1.01);
  }

  .fab-strip {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--brand-highlight);
    box-shadow: 0 0 8px var(--brand-highlight);
  }

  .fab-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--brand-highlight);
    color: #ffffff;
    flex-shrink: 0;
    transition: all 0.3s;
    border-radius: 2px;
    box-shadow: 0 2px 8px rgba(244, 145, 29, 0.3);
  }
  
  .fab-btn:hover .fab-icon {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 4px 12px rgba(244, 145, 29, 0.5);
  }

  .fab-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .fab-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.125rem;
  }
  .fab-value {
    font-weight: 900;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
    color: var(--brand-highlight);
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  @keyframes fab-enter {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  /* Pulse animation to draw attention */
  @keyframes fab-pulse {
    0%, 100% {
      box-shadow: 0 8px 32px rgba(244, 145, 29, 0.4), 0 4px 16px rgba(0,0,0,0.3);
    }
    50% {
      box-shadow: 0 8px 32px rgba(244, 145, 29, 0.6), 0 4px 16px rgba(0,0,0,0.3), 0 0 0 8px rgba(244, 145, 29, 0.2);
    }
  }
  
  .fab-btn {
    animation: fab-pulse 2s ease-in-out infinite;
  }
  
  .fab-btn:hover {
    animation: none;
  }
</style>
